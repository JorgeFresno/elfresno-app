async function cargarUsuarios() {
  try {
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=Usuarios`;
    const res  = await fetch(url);
    const text = await res.text();
    const json = JSON.parse(text.substring(47).slice(0, -2));
    const rows = json.table.rows || [];
    allUsuarios = rows.map(function(row) {
      return {
        id:      String(row.c[0]?.v || '').trim(),
        nombre:  String(row.c[1]?.v || '').trim(),
        pass:    String(row.c[2]?.v || '').trim(),
        rol:     String(row.c[3]?.v || '').trim(),
        activo:  String(row.c[4]?.v || '').trim().toUpperCase() === 'SI'
      };
    }).filter(function(u){ return u.id; });
    return allUsuarios;
  } catch(e) {
    console.error('Error cargando usuarios:', e);
    return [];
  }
}

function generarSiguienteId() {
  const ids = allUsuarios.map(function(u){ return parseInt(u.id.replace('U','')) || 0; });
  const max  = ids.length ? Math.max.apply(null, ids) : 0;
  return 'U' + String(max + 1).padStart(2, '0');
}

