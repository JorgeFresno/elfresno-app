function agruparPedidos() {
  pedidosAgrupados = {};
  allPedidosRaw.forEach(row => {
    // Detectar la columna del folio (puede llamarse PedidoRQF, Pedido/RQF, etc.)
    const folio = row['Pedido/RQF'] || row['PedidoRQF'] || row['Pedido_RQF'] || Object.values(row)[0] || '';
    if (!folio) return;
    const folioStr = String(folio).trim();
    if (!pedidosAgrupados[folioStr]) {
      pedidosAgrupados[folioStr] = {
        folio: folioStr,
        cliente: row['Cliente'] || '',
        vendedor: row['Vendedor'] || '',
        fechaPedido: row['FechaPedido'] || '',
        fechaCompromiso: row['FechaCompromiso'] || '',
        diasRestantes: parseFloat(row['DiasRestantes'] || 0),
        estado: String(row['EstadoPedido'] || row['Estado'] || 'Pendiente').trim(),
        prioridad: row['Prioridad'] || '',
        lineas: []
      };
    }
    pedidosAgrupados[folioStr].lineas.push({
      clave: row['ClaveProducto'] || row['Clave'] || '',
      descripcion: row['Descripcion'] || row['Descripción'] || '',
      cantPz: parseFloat(row['CantidadPedida_Pz'] || row['CantidadPz'] || 0),
      cantKg: parseFloat(row['CantidadPedida_Kg'] || row['CantidadKg'] || 0),
      pzDisp: parseFloat(row['Pz_Disponibles'] || 0),
      kgDisp: parseFloat(row['Kg_Disponibles'] || 0),
      faltantePz: parseFloat(row['Faltante_Pz'] || 0),
      faltanteKg: parseFloat(row['Faltante_Kg'] || 0),
      semaforo: row['Semaforo'] || '',
      observaciones: row['Observaciones'] || '',
      rawRow: row
    });
  });
}

function updateAgendaKPIs() {
  const todos = Object.values(pedidosAgrupados);
  const activos = todos.filter(p => !['Despachado','Cancelado'].includes(p.estado));
  const urgentes = todos.filter(p => p.diasRestantes <= 0 && !['Despachado','Cancelado'].includes(p.estado));
  const despachados = todos.filter(p => p.estado === 'Despachado');
  
  document.getElementById('agKpiActivos').textContent = activos.length;
  document.getElementById('agKpiUrgentes').textContent = urgentes.length;
  document.getElementById('agKpiDespachados').textContent = despachados.length;

  // Badge en nav
  const badge = document.getElementById('navBadgeAgenda');
  if (urgentes.length > 0) {
    badge.textContent = urgentes.length;
    badge.style.display = 'block';
  } else {
    badge.style.display = 'none';
  }

  // Quick sub en inicio
  if (activos.length > 0) {
    document.getElementById('agendaQuickSub').textContent = `${activos.length} activos · ${urgentes.length} urgentes hoy`;
  }

  // Alertas
  renderAlertas();
}

