async function loadMovimientos() {
  try {
    const table = await fetchSheet('Movimientos');
    if (table && table.cols) {
      table.cols = table.cols.map(col => {
        if (col.label) col.label = col.label.replace(/[^\w\s\/áéíóúÁÉÍÓÚñÑ]/gu, '').trim();
        return col;
      });
    }
    const rows = tableToObjects(table);
    // La primera columna viene como "MOVIMIENTOS  CONTROL GENERAL   FechaMov"
    // Normalizar TODAS las columnas extrayendo la última palabra significativa si tienen espacios largos
    rows.forEach(row => {
      Object.keys(row).forEach(k => {
        if (k.includes('  ')) {
          // Clave tiene espacios dobles = título pegado, extraer parte después del último espacio largo
          const partes = k.trim().split(/\s{2,}/);
          const keyLimpio = partes[partes.length - 1].trim();
          if (keyLimpio && keyLimpio !== k && !row[keyLimpio]) {
            row[keyLimpio] = row[k];
          }
        }
      });
    });
    allMovimientosCompletos = rows;
    console.log('MOV[0] keys:', JSON.stringify(Object.keys(rows[0]||{})));
    console.log('MOV[0] FolioMov:', rows[0]?.['FolioMov'], '| DocRef:', rows[0]?.['DocumentoRef']);

    // Cargar todos los movimientos del año actual + año anterior
    const anioActual = new Date().getFullYear();
    const movsFiltrados = rows.filter(r => {
      const f = r['FechaMov'] || r['Fecha'] || r['fecha'] || '';
      if (!f) return true; // incluir sin fecha
