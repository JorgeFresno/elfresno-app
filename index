// ── IMPORTAR PEDIDO DESDE EXCEL ──────────────────────────
let importPedidoDatos = null;

async function importarPedidoXLSX(input) {
  const file = input.files[0];
  if (!file) return;
  input.value = ''; // reset para permitir reimportar mismo archivo

  try {
    const data = await file.arrayBuffer();
    const wb   = XLSX.read(data, { type: 'array', cellDates: true });
    const ws   = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });

    // Datos del encabezado del pedido
    const numeroPedido = rows[2]?.[9] || '—';                    // fila 3 col J
    const fechaPedido  = rows[1]?.[9];                           // fila 2 col J
    const fechaEntrega = rows[8]?.[8];                           // fila 9 col I
    const cliente      = rows[5]?.[1] || '—';                   // fila 6 col B
    const agente       = rows[5]?.[5] || '—';                   // fila 6 col F

    // Buscar fila de encabezados de productos
    let headerRow = -1;
    for (let i = 0; i < rows.length; i++) {
      const r = rows[i];
      if (r && r.some(v => String(v || '').toUpperCase().includes('LINEA'))) {
        headerRow = i;
        break;
      }
    }
    if (headerRow < 0) { showToast('No se encontró tabla de productos', 'error'); return; }

    // Columnas: A=Clave, B=Cantidad, C=Linea/Area, D=Producto, I=Precio, J=Total
    const productosGSF = [];
    for (let i = headerRow + 1; i < rows.length; i++) {
      const r = rows[i];
      if (!r) continue;
      const clave    = String(r[0] || '').trim();
      const cantidad = parseFloat(r[1]) || 0;
      const linea    = String(r[2] || '').trim().toUpperCase();
      const producto = String(r[3] || '').trim();
      const precio   = parseFloat(r[8]) || 0;
      const total    = parseFloat(r[9]) || 0;

      if (linea === 'GSF' && clave && cantidad > 0) {
        productosGSF.push({ clave, cantidad, linea, producto, precio, total });
      }
    }

    if (!productosGSF.length) {
      showToast('No se encontraron productos GSF en este archivo', 'error');
      return;
    }

    // Formatear fechas
    const fmtFecha = v => {
      if (!v) return '—';
      if (v instanceof Date) return v.toLocaleDateString('es-MX');
      return String(v);
    };

    importPedidoDatos = { numeroPedido, fechaPedido, fechaEntrega, cliente, agente, productosGSF };

    // Mostrar en modal
    const infoEl = document.getElementById('importPedidoInfo');
    infoEl.innerHTML =
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">' +
      '<div><span style="color:#888;font-size:11px;">PEDIDO</span><div style="font-weight:800;">#' + numeroPedido + '</div></div>' +
      '<div><span style="color:#888;font-size:11px;">CLIENTE</span><div style="font-weight:800;">' + cliente + '</div></div>' +
      '<div><span style="color:#888;font-size:11px;">AGENTE</span><div style="font-weight:700;">' + agente + '</div></div>' +
      '<div><span style="color:#888;font-size:11px;">ENTREGA</span><div style="font-weight:700;">' + fmtFecha(fechaEntrega) + '</div></div>' +
      '</div>';

    const totalPedido = productosGSF.reduce((s, p) => s + p.total, 0);
    const prodEl = document.getElementById('importPedidoProductos');
    prodEl.innerHTML =
      '<div style="font-size:11px;font-weight:700;color:#888;text-transform:uppercase;margin-bottom:8px;">' +
      productosGSF.length + ' producto(s) GSF · $' + totalPedido.toLocaleString('es-MX', {minimumFractionDigits:2}) + '</div>' +
      productosGSF.map(p =>
        '<div style="background:#F9F9F9;border-radius:10px;padding:10px 12px;margin-bottom:8px;border:1px solid var(--border);">' +
        '<div style="display:flex;justify-content:space-between;align-items:start;">' +
        '<div style="font-size:13px;font-weight:800;color:#1B3A10;flex:1;">' + p.producto + '</div>' +
        '<div style="font-size:13px;font-weight:900;color:var(--green-dark);margin-left:8px;">' + p.cantidad.toLocaleString('es-MX') + ' pz</div>' +
        '</div>' +
        '<div style="display:flex;justify-content:space-between;margin-top:4px;">' +
        '<div style="font-size:11px;color:#888;">' + p.clave + '</div>' +
        '<div style="font-size:11px;color:#555;font-weight:700;">$' + p.precio.toLocaleString('es-MX', {minimumFractionDigits:2}) + ' c/u · $' + p.total.toLocaleString('es-MX', {minimumFractionDigits:2}) + '</div>' +
        '</div>' +
        '</div>'
      ).join('');

    abrirModal('importPedidoOverlay');

  } catch(e) {
    console.error('importarPedidoXLSX:', e);
    showToast('Error al leer el archivo: ' + e.message, 'error');
  }
}

async function confirmarImportPedido() {
  if (!importPedidoDatos) return;
  const { numeroPedido, fechaEntrega, cliente, agente, productosGSF } = importPedidoDatos;
  const btn = document.getElementById('btnConfirmarImport');
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span>Guardando...';

  const fmtFecha = v => {
    if (!v) return new Date().toLocaleDateString('es-MX');
    if (v instanceof Date) return v.toLocaleDateString('es-MX');
    return String(v);
  };

  // Crear un pedido por cada producto GSF
  let guardados = 0;
  for (const p of productosGSF) {
    const movId = 'IMP-' + Date.now() + '-' + Math.random().toString(36).substr(2,4);
    const payload = {
      accion:        'guardarPedido',
      Cliente:       cliente,
      Agente:        agente,
      NumeroPedido:  String(numeroPedido),
      Producto:      p.producto,
      Clave:         p.clave,
      Cantidad:      p.cantidad,
      Unidad:        'Pz',
      PrecioUnitario: p.precio,
      Total:         p.total,
      FechaEntrega:  fmtFecha(fechaEntrega),
      Estado:        'Pendiente',
      Origen:        'ImportXLSX',
      movId
    };
    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST', mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(payload)
      });
      guardados++;
    } catch(e) { console.error(e); }
  }

  btn.disabled = false;
  btn.innerHTML = '✓ Crear pedido en agenda';
  cerrarModal('importPedidoOverlay');
  showToast('✅ ' + guardados + ' producto(s) importados al pedido #' + numeroPedido, 'success');
  importPedidoDatos = null;
  setTimeout(() => sincronizarAgenda(), 1500);
}

