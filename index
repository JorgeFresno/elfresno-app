function renderGraficaMensual() {
  const container = document.getElementById('dashGraficaMensual');
  if (!container || !allMovimientosCompletos?.length) {
    if (container) container.innerHTML = '<div style="text-align:center;color:#aaa;padding:20px;font-size:12px;">Sin datos de movimientos</div>';
    return;
  }

  // Últimos 6 meses
  const hoy      = new Date();
  const meses    = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date(hoy.getFullYear(), hoy.getMonth() - i, 1);
    meses.push({ anio: d.getFullYear(), mes: d.getMonth(), label: d.toLocaleDateString('es-MX', { month: 'short', year: '2-digit' }) });
  }

  // Calcular entradas y salidas por mes
  const datos = meses.map(m => {
    const movsMes = allMovimientosCompletos.filter(mv => {
      const fStr = String(mv['FechaMov'] || '');
      let fecha = null;
      if (fStr.startsWith('Date(')) {
        const p = fStr.replace('Date(','').replace(')','').split(',').map(Number);
        fecha = new Date(p[0], p[1], p[2]);
      } else { fecha = new Date(fStr); }
      return fecha && !isNaN(fecha) && fecha.getFullYear() === m.anio && fecha.getMonth() === m.mes;
    });

    const campo = graficaTipo === 'pz' ? 'CantidadPz' : 'CantidadKg';
    const entradas = movsMes.filter(mv => ENTRADAS.includes(String(mv['TipoMov']||'')))
      .reduce((s, mv) => s + (parseFloat(mv[campo]) || 0), 0);
    const salidas  = movsMes.filter(mv => SALIDAS.includes(String(mv['TipoMov']||'')))
      .reduce((s, mv) => s + (parseFloat(mv[campo]) || 0), 0);

    return { ...m, entradas, salidas };
  });

  const maxVal = Math.max(...datos.map(d => Math.max(d.entradas, d.salidas)), 1);
  const barW   = 28;
  const gap    = 10;
  const groupW = barW * 2 + gap + 16;
  const chartH = 120;
  const totalW = datos.length * groupW + 20;
  const fmtNum = n => n >= 1000000 ? (n/1000000).toFixed(1)+'M' : n >= 1000 ? (n/1000).toFixed(0)+'k' : n.toFixed(0);

  let bars = '';
  datos.forEach((d, i) => {
    const x        = i * groupW + 10;
    const hEnt     = Math.round((d.entradas / maxVal) * chartH);
    const hSal     = Math.round((d.salidas  / maxVal) * chartH);
    const yEnt     = chartH - hEnt;
    const ySal     = chartH - hSal;
    const esActual = d.anio === hoy.getFullYear() && d.mes === hoy.getMonth();

    bars += `<g>
      <!-- Entrada -->
      <rect x="${x}" y="${yEnt}" width="${barW}" height="${hEnt}" rx="4" fill="${esActual ? '#1B3A10' : '#4A8C2A'}" opacity="${esActual ? 1 : 0.7}"/>
      ${d.entradas > 0 ? `<text x="${x + barW/2}" y="${yEnt - 3}" text-anchor="middle" font-size="8" fill="#2D5A1B" font-weight="700">${fmtNum(d.entradas)}</text>` : ''}
      <!-- Salida -->
      <rect x="${x + barW + 4}" y="${ySal}" width="${barW}" height="${hSal}" rx="4" fill="${esActual ? '#BF360C' : '#E65100'}" opacity="${esActual ? 1 : 0.7}"/>
      ${d.salidas > 0 ? `<text x="${x + barW + 4 + barW/2}" y="${ySal - 3}" text-anchor="middle" font-size="8" fill="#BF360C" font-weight="700">${fmtNum(d.salidas)}</text>` : ''}
      <!-- Label mes -->
      <text x="${x + barW + 2}" y="${chartH + 14}" text-anchor="middle" font-size="9" fill="${esActual ? '#1B3A10' : '#888'}" font-weight="${esActual ? '800' : '600'}">${d.label}</text>
      ${esActual ? `<rect x="${x - 4}" y="${chartH + 18}" width="${groupW - 4}" height="2" rx="1" fill="#1B3A10"/>` : ''}
    </g>`;
  });

  container.innerHTML = `<svg viewBox="0 0 ${totalW} ${chartH + 28}" xmlns="http://www.w3.org/2000/svg" style="width:100%;min-width:${totalW}px;overflow:visible;">
    <!-- Líneas guía -->
    ${[0.25, 0.5, 0.75, 1].map(pct => {
      const y = chartH - Math.round(pct * chartH);
      return `<line x1="0" y1="${y}" x2="${totalW}" y2="${y}" stroke="#f0f0f0" stroke-width="1"/>
              <text x="2" y="${y - 2}" font-size="7" fill="#ccc">${fmtNum(maxVal * pct)}</text>`;
    }).join('')}
    ${bars}
  </svg>`;
}

