  return '<div style="background:white;border-radius:14px;border:1px solid var(--border);padding:14px;margin-bottom:8px;">' +
    '<div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">' +
    '<div style="font-size:13px;font-weight:800;color:#1B3A10;">' + (r['Nombre'] || r['Descripcion'] || '—') + '</div>' +
    '<span style="background:' + badgeBg + ';color:' + badgeCol + ';border-radius:20px;padding:3px 10px;font-size:10px;font-weight:800;">' + tipo + '</span>' +
    '</div>' +
