// ── CANCELAR TODOS LOS MOVIMIENTOS DE UN GRUPO ──
async function cancelarGrupoMovimientos(docRefEnc) {
  const docRef = decodeURIComponent(docRefEnc);
  const movs   = allMovimientos.filter(m => {
    const d = String(m['DocumentoRef']||'').trim();
    const f = String(m['FolioMov']||'').trim();
    return (d === docRef || (!d && f === docRef)) && (m['Estado']||'') !== 'Cancelado';
  });
  if (!movs.length) { showToast('No hay movimientos activos para cancelar', ''); return; }

  return new Promise(resolve => {
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.65);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;';
    overlay.innerHTML = `
      <div style="background:white;border-radius:20px;padding:24px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          <div style="width:44px;height:44px;background:#FDECEA;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">🚫</div>
          <div>
            <div style="font-weight:700;font-size:16px;color:#C62828;">Cancelar grupo</div>
            <div style="font-size:12px;color:#888;font-family:'DM Mono',monospace;">${docRef} · ${movs.length} movimiento${movs.length>1?'s':''}</div>
          </div>
        </div>
        <div style="background:#FFF3E0;border:1px solid #FFE082;border-radius:10px;padding:10px 12px;font-size:12px;color:#E65100;margin-bottom:14px;">
          ⚠️ Se cancelarán ${movs.length} movimiento${movs.length>1?'s':''}. El stock regresará a su estado anterior.
        </div>
        <div style="font-size:13px;font-weight:600;color:#333;margin-bottom:6px;">Motivo de cancelación <span style="color:#E53935;">*</span></div>
        <textarea id="cancelGrupoMotivo" placeholder="Describe el motivo..." style="width:100%;min-height:70px;border:1.5px solid #ddd;border-radius:10px;padding:10px 12px;font-size:14px;font-family:inherit;resize:vertical;box-sizing:border-box;outline:none;" onfocus="this.style.borderColor='#E53935'" onblur="this.style.borderColor='#ddd'"></textarea>
        <div id="cancelGrupoError" style="color:#E53935;font-size:12px;margin-top:4px;display:none;">El motivo es obligatorio</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;">
          <button id="cancelGrupoNo" style="padding:13px;border-radius:12px;border:1.5px solid #ddd;background:white;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;">No, regresar</button>
          <button id="cancelGrupoSi" style="padding:13px;border-radius:12px;border:none;background:#E53935;color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;">Sí, cancelar todo</button>
        </div>
      </div>`;
    document.body.appendChild(overlay);

    document.getElementById('cancelGrupoNo').onclick = () => { overlay.remove(); resolve(false); };
    document.getElementById('cancelGrupoSi').onclick = async () => {
      const motivo = document.getElementById('cancelGrupoMotivo').value.trim();
      if (!motivo) { document.getElementById('cancelGrupoError').style.display = 'block'; return; }
      overlay.remove();
      document.getElementById('detModalOverlay').classList.remove('open');

      showToast(`⏳ Cancelando ${movs.length} movimientos...`, '');
      let cancelados = 0;
      for (let i = 0; i < movs.length; i++) {
        const folio = movs[i]['FolioMov'] || '';
        if (!folio) continue;
        try {
          await fetch(APPS_SCRIPT_URL, {
            method: 'POST', mode: 'no-cors',
            headers: { 'Content-Type': 'text/plain' },
            body: JSON.stringify({
              accion: 'cancelar',
              FolioMov: folio,
              Motivo: motivo,
              Captura: currentUser?.nombre || 'Sistema'
            })
          });
          cancelados++;
          if (i < movs.length - 1) await new Promise(r => setTimeout(r, 350));
        } catch(e) { console.error('Error cancelando', folio, e); }
      }
      // Actualizar estado local de todos los movimientos del grupo
      movs.forEach(m => { m['Estado'] = 'Cancelado'; });
      showToast(`✅ ${cancelados} movimiento${cancelados>1?'s':''} cancelado${cancelados>1?'s':''}`, 'success');
      // Re-abrir el modal de grupo con estado actualizado
      const docRefActual = movs[0] ? (movs[0]['DocumentoRef']||movs[0]['FolioMov']||'') : '';
      if (docRefActual) setTimeout(() => abrirGrupoMovimientos(encodeURIComponent(docRefActual)), 300);
      setTimeout(() => syncData(), 2000);
      resolve(true);
    };
  });
}

// ── TICKET DE RECEPCIÓN (grupo completo) ──
