async function submitNuevoPedido() {
  const folio = document.getElementById('npFolio').value.trim();
  const cliente = document.getElementById('npCliente').value || document.getElementById('npClienteSearch').value.trim();
  const vendedor = document.getElementById('npVendedor').value.trim();
  const estado = document.getElementById('npEstado').value;
  const prioridad = document.getElementById('npPrioridad').value;
  const fechaPedido = document.getElementById('npFechaPedido').value;
  const fechaCompromiso = document.getElementById('npFechaCompromiso').value;
  const obs = document.getElementById('npObs').value.trim();

  if (!folio) { showToast('⚠️ Ingresa el número de pedido', 'error'); return; }
  if (!cliente) { showToast('⚠️ Selecciona un cliente', 'error'); return; }

  // Recopilar líneas
  const lineas = [];
  for (let i = 1; i <= npLineasCount; i++) {
    const clave = document.getElementById(`npClave_${i}`)?.value;
    if (!clave) continue; // líneas sin producto se omiten
    lineas.push({
      ClaveProducto: clave,
      Descripcion: document.getElementById(`npDesc_${i}`)?.value || '',
      CantidadPedida_Pz: parseFloat(document.getElementById(`npPz_${i}`)?.value) || 0,
      CantidadPedida_Kg: parseFloat(document.getElementById(`npKg_${i}`)?.value) || 0,
      Observaciones: document.getElementById(`npObsLinea_${i}`)?.value || '',
    });
  }

  if (lineas.length === 0) { showToast('⚠️ Agrega al menos un producto', 'error'); return; }

  const btn = document.getElementById('npSubmitBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Guardando...';

  // Construir payload: una fila por línea
  const filas = lineas.map(l => ({
    accion: 'nuevoPedido',
    'Pedido/RQF': folio,
    FechaPedido: fechaPedido,
    FechaCompromiso: fechaCompromiso,
    Cliente: cliente,
    Vendedor: vendedor,
    ClaveProducto: l.ClaveProducto,
    Descripcion: l.Descripcion,
    CantidadPedida_Pz: l.CantidadPedida_Pz,
    CantidadPedida_Kg: l.CantidadPedida_Kg,
    EstadoPedido: estado,
    Prioridad: prioridad,
    Observaciones: l.Observaciones || obs,
  }));

  try {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({ accion: 'nuevoPedidoMultiple', filas })
    });
    showToast(`✅ Pedido ${folio} guardado · ${lineas.length} productos`, 'success');
    cerrarModal('nuevoPedidoModalOverlay');
    setTimeout(() => loadAgenda(), 2000);
  } catch(e) {
    showToast('❌ Error al guardar pedido', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '💾 Guardar pedido';
  }
}

// ==========================================
//  INVENTARIO
// ==========================================
function getStatus(p) {
  const isGranel  = p.tipo === 'granel';
  const stock     = isGranel ? (p.stockKg || 0)      : (p.stockPz || 0);
  const reservado = isGranel ? (p.reservadoKg || 0)  : (p.reservado || 0);
  const disponible= isGranel ? (p.disponibleKg || 0) : (p.disponible || 0);

  if (stock === 0) return 'zero';

  // Si no hay nada reservado, no hay presión — siempre OK
  if (reservado === 0) return 'ok';

  // % disponible sobre el stock total
  const pct = stock > 0 ? disponible / stock : 0;
  if (pct <= 0)    return 'zero';
  if (pct < 0.20)  return 'critico';
  if (pct < 0.50)  return 'bajo';
  return 'ok';
}

function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll('#page-inventario .filter-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderProducts();
}

function renderProducts() {
  const search = (document.getElementById('searchInput')?.value || '').toLowerCase();
  let filtered = [...allProducts];
  if (currentFilter === 'empacado') filtered = filtered.filter(p => p.tipo === 'empacado');
  else if (currentFilter === 'granel') filtered = filtered.filter(p => p.tipo === 'granel');
  else if (currentFilter === 'ok') filtered = filtered.filter(p => getStatus(p) === 'ok');
  else if (currentFilter === 'bajo') filtered = filtered.filter(p => getStatus(p) === 'bajo');
  else if (currentFilter === 'critico') filtered = filtered.filter(p => getStatus(p) === 'critico');
  if (search) filtered = filtered.filter(p => p.clave.toLowerCase().includes(search) || p.nombre.toLowerCase().includes(search));

  const container = document.getElementById('productsContainer');
  if (!filtered.length) { container.innerHTML = '<div class="empty-state">No se encontraron productos</div>'; return; }
  container.innerHTML = filtered.map(p => {
    const status = getStatus(p);
    const isGranel = p.tipo === 'granel';
    const stock = isGranel ? (p.stockKg || 0) : p.stockPz;
    const reservado = isGranel ? (p.reservadoKg || 0) : p.reservado;
    const disponible = isGranel ? (p.disponibleKg || 0) : p.disponible;
    const unidad = isGranel ? 'kg' : 'pz';
    const pct = stock > 0 ? Math.min(100, Math.round((disponible / stock) * 100)) : 0;
    const statusMap = { ok:['status-ok','fill-green','Normal'], bajo:['status-low','fill-orange','Bajo'], critico:['status-critical','fill-red','Crítico'], zero:['status-zero','fill-gray','Sin stock'] };
    const [chipClass, fillClass, label] = statusMap[status];
    return `<div class="product-card" onclick="openProdDetalle('${p.clave}')">
      <div class="product-header">
        <div><div class="product-name">${p.nombre}</div><div class="product-code">${p.clave}${p.gramaje ? ' · '+p.gramaje : ''} · ${isGranel?'Granel':'PT'}</div></div>
        <div class="status-chip ${chipClass}"><div class="chip-dot"></div>${label}</div>
      </div>
      <div class="progress-bar"><div class="progress-fill ${fillClass}" style="width:${pct}%"></div></div>
      <div class="product-stats">
        <div class="stat"><div class="stat-value">${formatNum(stock)}</div><div class="stat-label">Stock ${unidad}</div></div>
        <div class="stat"><div class="stat-value orange">${formatNum(reservado)}</div><div class="stat-label">Reservado</div></div>
        <div class="stat"><div class="stat-value green">${formatNum(disponible)}</div><div class="stat-label">Disponible</div></div>
        <div class="stat"><div class="stat-value">${pct}%</div><div class="stat-label">Cap.</div></div>
      </div>
    </div>`;
  }).join('');
}

function updateKPIs() {
  const emp = allProducts.filter(p => p.tipo === 'empacado');
  const gran = allProducts.filter(p => p.tipo === 'granel');
  const totalPz = emp.reduce((s,p) => s + p.stockPz, 0);
  const totalKg = gran.reduce((s,p) => s + (p.stockKg || 0), 0);
  const totalRes = emp.reduce((s,p) => s + p.reservado, 0);
  const totalDisp = emp.reduce((s,p) => s + p.disponible, 0);
  document.getElementById('kpiTotalPz').textContent = formatNum(totalPz);
  document.getElementById('kpiTotalKg').textContent = formatNum(totalKg);
  document.getElementById('kpiProductos').textContent = allProducts.length;
  document.getElementById('invTotalPz').textContent = formatNum(totalPz);
  document.getElementById('invTotalKg').textContent = formatNum(totalKg);
  document.getElementById('invReservado').textContent = formatNum(totalRes);
  document.getElementById('invDisponible').textContent = formatNum(totalDisp);
  document.getElementById('invBadgeRes').textContent = totalRes > 0 ? formatNum(totalRes)+' pz' : 'Sin reservas';

  const criticos = allProducts.filter(p => getStatus(p) === 'critico');
  const alertsTitle = document.getElementById('alertsTitle');
  const alertsContainer = document.getElementById('alertsContainer');
  if (criticos.length > 0) {
    alertsTitle.style.display = 'flex';
    alertsContainer.innerHTML = criticos.slice(0, 3).map(p => `
      <div class="alert-card critical">
        <div class="alert-dot red"></div>
        <div class="alert-body">
          <div class="alert-title red">Stock crítico: ${p.clave}</div>
          <div class="alert-sub">${p.nombre} · ${formatNum(p.stockPz)} pz disponibles</div>
        </div>
      </div>`).join('');
  } else {
    alertsTitle.style.display = 'none';
    alertsContainer.innerHTML = '';
  }
}

// ==========================================
//  MOVIMIENTOS
// ==========================================
const ENTRADAS = ['Entrada compra','Entrada devolución','Ajuste positivo','Entrada producción'];
const SALIDAS = ['Salida venta','Salida a producción','Consumo tolva','Ajuste negativo','Merma','Desecho','Salida venta/despacho'];

function renderMovimientos() {
  const container = document.getElementById('movContainer');
  if (!allMovimientos.length) { container.innerHTML = '<div class="empty-state">No hay movimientos disponibles</div>'; return; }

  // ── Filtros ──
  const movSearch = (document.getElementById('movSearchInput')?.value || '').toLowerCase().trim();
  let movsFiltrados = allMovimientos;
  if (movSearch) {
    movsFiltrados = allMovimientos.filter(m => {
      const folio   = String(m['FolioMov']      || m['DocumentoRef'] || '').toLowerCase();
      const tipo    = String(m['TipoMov']       || '').toLowerCase();
      const clave   = String(m['ClaveProducto'] || '').toLowerCase();
      const cliente = String(m['Cliente']       || m['Proveedor'] || '').toLowerCase();
      const fecha   = String(m['FechaMov']      || '').toLowerCase();
      return folio.includes(movSearch) || tipo.includes(movSearch) ||
             clave.includes(movSearch) || cliente.includes(movSearch) ||
             fecha.includes(movSearch);
    });
  }

  if (!movsFiltrados.length) {
    container.innerHTML = '<div class="empty-state">🔍 Sin resultados para "' + movSearch + '"</div>';
    return;
  }

  // ── AGRUPAR por DocumentoRef ──
  const grupos = {};
  // Debug primera fecha
  if (allMovimientos.length > 0) {
    const m0 = allMovimientos[0];
    console.log('DEBUG FechaMov[0]:', JSON.stringify(m0['FechaMov']), typeof m0['FechaMov']);
  }
  movsFiltrados.forEach(m => {
    const docRef = String(m['DocumentoRef'] || '').trim();
    const folio  = String(m['FolioMov']     || '').trim();
    const key    = docRef || folio || '—';
    if (!grupos[key]) grupos[key] = { key, movs: [] };
    grupos[key].movs.push(m);
  });
  const listaGrupos = Object.values(grupos);

  // ── AGRUPAR por trimestre ──
  const hoy       = new Date();
  const trimActual = Math.floor(hoy.getMonth() / 3); // 0-3
  const anioActual = hoy.getFullYear();

  const trimestres = [
    { label: 'Q1 · Ene–Mar', meses: [0,1,2],  id: 'q1' },
    { label: 'Q2 · Abr–Jun', meses: [3,4,5],  id: 'q2' },
    { label: 'Q3 · Jul–Sep', meses: [6,7,8],  id: 'q3' },
    { label: 'Q4 · Oct–Dic', meses: [9,10,11], id: 'q4' }
  ];

  // Clasificar grupos por trimestre
  const gruposPorTrim = { q1:[], q2:[], q3:[], q4:[], sinFecha:[] };
  listaGrupos.forEach(g => {
    const m0    = g.movs[0];
    const fStr  = String(m0['FechaMov'] || '');
    // Parsear fecha — puede venir como Date(2026,2,17), 2026-03-17, o Date object
    let fecha = null;
    if (fStr.startsWith('Date(')) {
      const p = fStr.replace('Date(','').replace(')','').split(',').map(Number);
      fecha = new Date(p[0], p[1], p[2]);
    } else if (fStr) {
      fecha = new Date(fStr);
    }
    if (!fecha || isNaN(fecha)) { gruposPorTrim.sinFecha.push(g); return; }
    const mes   = fecha.getMonth();
    const tri   = Math.floor(mes / 3);
    const keys  = ['q1','q2','q3','q4'];
    gruposPorTrim[keys[tri]].push(g);
  });

  // Renderizar cada grupo como tarjeta
  function renderGrupoCard(g) {
    const movs = g.movs;
    const m0   = movs[0];
    const tipo = m0['TipoMov'] || '';
    const esEntrada  = ENTRADAS.includes(tipo);
    const iconMap2   = {
      'Entrada compra':    ['📥','icon-green'],  'Salida venta':     ['📦','icon-orange'],
      'Salida despacho':   ['🚀','icon-orange'], 'Ajuste positivo':  ['➕','icon-teal'],
      'Ajuste negativo':   ['➖','icon-red'],    'Recepcion lote':   ['📥','icon-green'],
      'Traslado':          ['🔄','icon-blue'],
    };
    const [icon, iconClass] = iconMap2[tipo] || ['📋','icon-blue'];
    const docRef    = String(m0['DocumentoRef'] || m0['FolioMov'] || '—');
    const fecha     = String(m0['FechaMov'] || '—').split(' ')[0];
    const cliente   = String(m0['Cliente']  || m0['Proveedor'] || '—');
    const productos = [...new Set(movs.map(m => String(m['ClaveProducto']||'').trim()).filter(Boolean))];
    const totalKg   = movs.reduce((s,m) => s + (parseFloat(m['CantidadKg']||0)), 0);
    const totalPz   = movs.reduce((s,m) => s + (parseFloat(m['CantidadPz']||0)), 0);
    const resumen   = (totalPz > 0 ? totalPz.toLocaleString('es-MX') + ' pz' : '') +
                      (totalPz > 0 && totalKg > 0 ? ' · ' : '') +
                      (totalKg > 0 ? totalKg.toLocaleString('es-MX') + ' kg' : '');
    return '<div class="mov-grupo-card" data-docref="' + docRef.replace(/"/g,"'") + '" onclick="openGrupoDetalle(this.dataset.docref)">'+  
      '<div class="mov-grupo-header">' +
      '<div class="action-icon ' + iconClass + '" style="width:38px;height:38px;font-size:16px;">' + icon + '</div>' +
      '<div class="mov-grupo-info">' +
      '<div class="mov-grupo-folio">' + docRef + '</div>' +
      '<div class="mov-grupo-sub">' + tipo + (cliente !== '—' ? ' · ' + cliente : '') + '</div>' +
      '</div>' +
      '<div class="mov-grupo-right">' +
      '<div class="mov-grupo-fecha">' + fecha + '</div>' +
      (resumen ? '<div class="mov-grupo-qty ' + (esEntrada ? 'qty-entrada' : 'qty-salida') + '">' + resumen + '</div>' : '') +
      '</div></div>' +
      (productos.length ? '<div class="mov-grupo-prods">' + productos.slice(0,3).join(' · ') + (productos.length > 3 ? ' +' + (productos.length-3) : '') + '</div>' : '') +
      '</div>';
  }

  // Construir HTML por trimestres
  let html = '';
  const trimOrden = [3,2,1,0]; // Q4 primero (más reciente)
  trimOrden.forEach(triIdx => {
    const tri       = trimestres[triIdx];
    const grupos_t  = gruposPorTrim[tri.id];
    if (!grupos_t.length) return;

    const esActual  = triIdx === trimActual;
    const totalMovs = grupos_t.reduce((s, g) => s + g.movs.length, 0);
    const entradas  = grupos_t.filter(g => ENTRADAS.includes(g.movs[0]['TipoMov'])).length;
    const salidas   = grupos_t.length - entradas;

    html += '<div class="trim-section" id="trim-' + tri.id + '">' +
      '<div class="trim-header" data-trimid="' + tri.id + '" onclick="toggleTrim(this.dataset.trimid)">' +
      '<div style="display:flex;align-items:center;gap:10px;">' +
      '<div style="font-size:15px;font-weight:900;color:#1B3A10;">' + tri.label + (esActual ? ' <span style="background:#E8F5E9;color:#2D5A1B;border-radius:20px;padding:2px 8px;font-size:10px;font-weight:700;">Actual</span>' : '') + '</div>' +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:10px;">' +
      '<div style="font-size:11px;color:#888;">' + grupos_t.length + ' docs · ' + totalMovs + ' movs</div>' +
      '<div style="font-size:18px;transition:transform 0.2s;" id="trim-arrow-' + tri.id + '">' + (esActual ? '▲' : '▼') + '</div>' +
      '</div></div>' +
      // Stats del trimestre
      '<div class="trim-stats" id="trim-stats-' + tri.id + '" style="' + (esActual ? '' : 'display:none;') + '">' +
      '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:10px 14px;background:#F9F9F9;border-bottom:1px solid var(--border);">' +
      '<div style="text-align:center;"><div style="font-size:16px;font-weight:900;color:#1B3A10;">' + grupos_t.length + '</div><div style="font-size:10px;color:#888;">Documentos</div></div>' +
      '<div style="text-align:center;"><div style="font-size:16px;font-weight:900;color:#2E7D32;">' + entradas + '</div><div style="font-size:10px;color:#888;">Entradas</div></div>' +
      '<div style="text-align:center;"><div style="font-size:16px;font-weight:900;color:#E65100;">' + salidas + '</div><div style="font-size:10px;color:#888;">Salidas</div></div>' +
      '</div></div>' +
      // Lista de grupos
      '<div class="trim-body" id="trim-body-' + tri.id + '" style="' + (esActual ? '' : 'display:none;') + '">' +
      grupos_t.map(g => renderGrupoCard(g)).join('') +
      '</div></div>';
  });

  // Sin fecha al final
  if (gruposPorTrim.sinFecha.length) {
    html += '<div style="padding:8px 14px;font-size:11px;color:#aaa;text-align:center;">Sin fecha: ' + gruposPorTrim.sinFecha.length + ' documentos</div>';
  }

  container.innerHTML = html ||  '<div class="empty-state">Sin movimientos</div>';
}

function toggleTrim(id) {
  const body  = document.getElementById('trim-body-'  + id);
  const stats = document.getElementById('trim-stats-' + id);
  const arrow = document.getElementById('trim-arrow-' + id);
  if (!body) return;
  const visible = body.style.display !== 'none';
  body.style.display  = visible ? 'none' : '';
  stats.style.display = visible ? 'none' : '';
  if (arrow) arrow.textContent = visible ? '▼' : '▲';
}


