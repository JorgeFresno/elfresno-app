function searchCatalog(inputId, hiddenId, list, sugId) {
  const q = document.getElementById(inputId).value.toLowerCase().trim();
  const sugBox = document.getElementById(sugId);
  document.getElementById(hiddenId).value = '';
  if (q.length < 1) { sugBox.style.display='none'; return; }
  const matches = list.filter(i => i.toLowerCase().includes(q)).slice(0,7);
  if (!matches.length) { sugBox.style.display='none'; return; }
  sugBox.innerHTML = matches.map(i => {
    const safe = i.replace(/"/g,'&quot;');
    return `<div class="suggestion-item" onclick="selectCatalogItem(this,'${hiddenId}','${inputId}','${sugId}')" data-value="${safe}">${i}</div>`;
  }).join('');
  sugBox.className = 'product-suggestion';
  sugBox.style.display = 'block';
}

function selectCatalogItem(el, hiddenId, inputId, sugId) {
  const value = el.getAttribute('data-value');
  document.getElementById(hiddenId).value = value;
  document.getElementById(inputId).value = value;
  document.getElementById(sugId).style.display = 'none';
}

