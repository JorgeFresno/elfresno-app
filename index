async function cargarDatosMaquilaDetalle(folio, silencioso = false) {
  if (!silencioso) {
    maqEntradasData   = [];
    maqProduccionData = [];
    maqSalidasData    = [];
  }

  try {
    const table = await fetchSheet('Maquilas_Recepcion', true);
    const rows  = tableToObjects(fixFirstHeader(table, 'Acta'));
    maqEntradasData = rows.filter(r => String(r['Acta'] || '').trim() === folio);
  } catch(e) { maqEntradasData = []; }

  try {
    const table = await fetchSheet('Maquilas_Produccion', true);
    const rows  = tableToObjects(fixFirstHeader(table, 'Acta'));
    maqProduccionData = rows
      .filter(r => String(r['Acta'] || '').trim() === folio)
      .map(r => {
        // Normalizar encabezados — Sheets puede tener KGVaciados o KgVaciados
        if (r['KGVaciados'] !== undefined && r['KgVaciados'] === undefined) r['KgVaciados'] = r['KGVaciados'];
        if (r['KGAcondicionados'] !== undefined && r['KgAcondicionados'] === undefined) r['KgAcondicionados'] = r['KGAcondicionados'];
        if (r['BultosVaciados'] === undefined && r['Bultos Vaciados'] !== undefined) r['BultosVaciados'] = r['Bultos Vaciados'];
        return r;
      });
  } catch(e) { maqProduccionData = []; }

  try {
    const table = await fetchSheet('Maquilas_Entregas', true);
    const rows  = tableToObjects(fixFirstHeader(table, 'Acta'));
    maqSalidasData = rows.filter(r => String(r['Acta'] || '').trim() === folio);
  } catch(e) { maqSalidasData = []; }

  actualizarKpisMaqDet();
  renderMaqDetTab(maqDetTabActual);
}

function fmaqFecha(val) {
  if (!val) return '—';
  const s = String(val);
  // Handle Date(2026,2,17) from Google Sheets
  const m = s.match(/Date\((\d+),(\d+),(\d+)\)/);
  if (m) {
    const y = m[1], mo = String(parseInt(m[2])+1).padStart(2,'0'), d = String(m[3]).padStart(2,'0');
    return d + '/' + mo + '/' + y;
  }
  // Handle 2026-03-10
  if (s.includes('-')) {
    const p = s.split('-');
    if (p.length === 3) return p[2].substring(0,2) + '/' + p[1] + '/' + p[0];
  }
  return s;
}

function actualizarKpisMaqDet() {
  // Solo filas OK (no canceladas)
  const entradasOK   = maqEntradasData.filter(e => e['Estado'] !== 'Cancelado' && !e._cancelado);
  const produccionOK = maqProduccionData.filter(p => p['Estado'] !== 'Cancelado');
  const salidasOK    = maqSalidasData.filter(e => e['Estado'] !== 'Cancelado');

  // KG recibidos total
  const kgRecibidos    = entradasOK.reduce((s, e) => s + (parseFloat(e['KgFresno']) || 0), 0);
  // KG vaciados a tolva
  const kgVaciados     = produccionOK.reduce((s, p) => s + (parseFloat(p['KgVaciados'] || p['KGVaciados']) || 0), 0);
  // KG acondicionados (limpios)
  const kgAcondicionados = produccionOK.reduce((s, p) => s + (parseFloat(p['KgAcondicionados']) || 0), 0);
  // KG entregados
  const kgEntregados   = salidasOK.reduce((s, e) => s + (parseFloat(e['PesoSalida']) || 0), 0);

  // Saldos calculados
  const kgBodega   = Math.max(0, kgRecibidos - kgVaciados);      // recibidos - vaciados
  const kgEnTolva  = Math.max(0, kgVaciados - kgAcondicionados); // vaciados - acondicionados
  const kgLimpios  = Math.max(0, kgAcondicionados - kgEntregados); // acondicionados - entregados

  const el = id => document.getElementById(id);
  if (el('maqDetKpiKg'))      el('maqDetKpiKg').textContent      = formatNum(kgBodega)   + ' kg';
  if (el('maqDetKpiTolva'))   el('maqDetKpiTolva').textContent   = formatNum(kgEnTolva)  + ' kg';
  if (el('maqDetKpiLimpios')) el('maqDetKpiLimpios').textContent = formatNum(kgLimpios)  + ' kg';
  if (el('maqDetKpiSalidas')) el('maqDetKpiSalidas').textContent = formatNum(kgEntregados) + ' kg';
}

