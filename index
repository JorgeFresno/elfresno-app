function searchProductoLinea(idx) {
  const q = document.getElementById(`npSearch_${idx}`).value.toLowerCase().trim();
  const sugBox = document.getElementById(`npSug_${idx}`);
  if (q.length < 2) { sugBox.style.display = 'none'; return; }
  const matches = allProducts.filter(p =>
    p.clave.toLowerCase().includes(q) || p.nombre.toLowerCase().includes(q)
  ).slice(0, 6);
  if (!matches.length) { sugBox.style.display = 'none'; return; }
  sugBox.innerHTML = matches.map(p => `
    <div class="suggestion-item" onclick="selectLineaProducto(${idx},'${p.clave}','${p.nombre.replace(/'/g,"\\'")}')">
      <div class="suggestion-name">${p.nombre}</div>
      <div class="suggestion-code">${p.clave} · ${p.tipo === 'granel' ? 'Granel' : 'PT'}</div>
    </div>`).join('');
  sugBox.className = 'product-suggestion';
  sugBox.style.display = 'block';
}

