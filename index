let alertasPanelAbierto = false;

function calcularAlertas() {
  const DIAS_PROXIMOS   = 3;
  const PORC_STOCK_BAJO = 0.5;  // menos del 50%
  const MIN_VOLUMINOSO  = 4000; // pz o kg

  const hoy   = new Date();
  hoy.setHours(0,0,0,0);

  const alertas = [];

  Object.values(pedidosAgrupados).forEach(p => {
    if (['Despachado','Cancelado'].includes(p.estado)) return;

    // Fecha próxima
    if (p.fechaCompromiso) {
      const partes = String(p.fechaCompromiso).split(/[-\/]/);
      let fecha;
      if (partes.length === 3) {
        // Intentar YYYY-MM-DD y DD/MM/YYYY
        fecha = partes[0].length === 4
          ? new Date(partes[0], partes[1]-1, partes[2])
          : new Date(partes[2], partes[1]-1, partes[0]);
        fecha.setHours(0,0,0,0);
        const diasRestantes = Math.ceil((fecha - hoy) / 86400000);
        if (diasRestantes <= DIAS_PROXIMOS) {
          alertas.push({
            tipo: 'fecha',
            icono: '🟡',
            folio: p.folio,
            cliente: p.cliente,
            msg: diasRestantes < 0
              ? 'Vencido hace ' + Math.abs(diasRestantes) + ' día(s)'
              : diasRestantes === 0
                ? 'Entrega HOY'
                : 'Entrega en ' + diasRestantes + ' día(s)'
          });
        }
      }
    }

    // Revisar líneas
    p.lineas.forEach(l => {
      const pedPz = l.cantPz;
      const pedKg = l.cantKg;
      const dispPz = l.pzDisp;
      const dispKg = l.kgDisp;
      const esGranel = pedKg > 0;
      const pedTotal = esGranel ? pedKg : pedPz;
      const dispTotal = esGranel ? dispKg : dispPz;
      const unidad = esGranel ? 'kg' : 'pz';

      if (pedTotal <= 0) return;

      const porcDisp = dispTotal / pedTotal;

      // Sin stock
      if (dispTotal <= 0) {
        // Voluminoso sin stock
        if (pedTotal >= MIN_VOLUMINOSO) {
          alertas.push({
            tipo: 'voluminoso',
            icono: '🔵',
            folio: p.folio,
            cliente: p.cliente,
            msg: l.clave + ': ' + pedTotal.toLocaleString('es-MX') + ' ' + unidad + ' pedidas — SIN STOCK (voluminoso)'
          });
        } else {
          alertas.push({
            tipo: 'sinstock',
            icono: '🔴',
            folio: p.folio,
            cliente: p.cliente,
            msg: l.clave + ': ' + pedTotal.toLocaleString('es-MX') + ' ' + unidad + ' pedidas — SIN STOCK'
          });
        }
      } else if (porcDisp < PORC_STOCK_BAJO) {
        // Stock bajo
        alertas.push({
          tipo: 'stockbajo',
          icono: '🟠',
          folio: p.folio,
          cliente: p.cliente,
          msg: l.clave + ': solo ' + Math.round(porcDisp*100) + '% disponible (' + dispTotal.toLocaleString('es-MX') + '/' + pedTotal.toLocaleString('es-MX') + ' ' + unidad + ')'
        });
      }
    });
  });

  return alertas;
}

function renderAlertas() {
  const alertas = calcularAlertas();
  const panel   = document.getElementById('alertasPanel');
  const body    = document.getElementById('alertasPanelBody');
  const resumen = document.getElementById('alertasResumen');
  const badge   = document.getElementById('navBadgeAgenda');

  if (!alertas.length) {
    panel.style.display = 'none';
    badge.style.display = 'none';
    return;
  }

  // Badge en nav
  badge.textContent = alertas.length;
  badge.style.display = 'block';

  // Resumen
  const sinStock  = alertas.filter(a => a.tipo === 'sinstock').length;
  const bajo      = alertas.filter(a => a.tipo === 'stockbajo').length;
  const fecha     = alertas.filter(a => a.tipo === 'fecha').length;
  const volum     = alertas.filter(a => a.tipo === 'voluminoso').length;
  const partes = [];
  if (sinStock) partes.push(sinStock + ' sin stock');
  if (volum)    partes.push(volum + ' voluminosos');
  if (bajo)     partes.push(bajo + ' stock bajo');
  if (fecha)    partes.push(fecha + ' fecha próxima');
  resumen.textContent = partes.join(' · ');

  // Contenido del panel
  body.innerHTML = alertas.map(a => `
    <div onclick="openPedidoDetalle('${encodeURIComponent(a.folio)}')" style="display:flex;align-items:flex-start;gap:10px;background:white;border-radius:10px;padding:10px 12px;cursor:pointer;border:1px solid #FFE082;">
      <span style="font-size:16px;flex-shrink:0;">${a.icono}</span>
      <div style="flex:1;min-width:0;">
        <div style="font-size:12px;font-weight:800;color:#1A1A1A;">${a.folio} <span style="color:#888;font-weight:500;">· ${a.cliente}</span></div>
        <div style="font-size:11px;color:#555;margin-top:2px;">${a.msg}</div>
      </div>
      <span style="color:#aaa;font-size:14px;">›</span>
    </div>
  `).join('');

  panel.style.display = 'block';
}

