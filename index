let dashPeriodo = 'mes';

function setDashPeriod(period, btn) {
  dashPeriodo = period;
  document.querySelectorAll('.dash-period-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderDashboard();
}

function getDashFiltroInicio() {
  const hoy = new Date();
  if (dashPeriodo === 'mes')       { const d = new Date(hoy.getFullYear(), hoy.getMonth(), 1); d.setHours(0,0,0,0); return d; }
  if (dashPeriodo === 'trimestre') { const d = new Date(hoy); d.setMonth(d.getMonth()-3); d.setHours(0,0,0,0); return d; }
  if (dashPeriodo === 'anio')      { const d = new Date(hoy.getFullYear(), 0, 1); d.setHours(0,0,0,0); return d; }
  return null;
}

function parseFechaMovimiento(str) {
  if (!str) return null;
  if (str instanceof Date) return str;
  const s = String(str).trim();
  const p = s.split(/[-\/]/);
  if (p.length === 3) {
    const a = parseInt(p[0]), b = parseInt(p[1]), c = parseInt(p[2]);
    if (p[0].length === 4) {
      // YYYY/MM/DD
      return new Date(a, b-1, c);
    } else if (c > 31) {
      // MM/DD/YYYY o DD/MM/YYYY — si c es año (>31)
      // Detectar: si a <= 12 y b > 12 → MM/DD/YYYY (americano)
      if (a <= 12 && b > 12) return new Date(c, a-1, b); // MM/DD/YYYY
      // Si a > 12 → DD/MM/YYYY
      if (a > 12) return new Date(c, b-1, a);
      // Ambiguo pero Sheets suele exportar MM/DD/YYYY
      return new Date(c, a-1, b);
    }
  }
  const d = new Date(s);
  if (!isNaN(d)) return d;
  return null;
}

