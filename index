function getPeriodoRango(key) {
  const hoy = new Date();
  const lunes = new Date(hoy); lunes.setDate(hoy.getDate() - ((hoy.getDay()+6)%7)); lunes.setHours(0,0,0,0);
  if (key.startsWith('sem')) {
    const n = parseInt(key.replace('sem',''));
    const ini = new Date(lunes); ini.setDate(lunes.getDate() - n*7);
    const fin = new Date(ini); fin.setDate(ini.getDate() + 6); fin.setHours(23,59,59,999);
    return { ini, fin, label: n === 0 ? 'Semana actual' : n === 1 ? 'Semana pasada' : `Hace ${n} semanas` };
  } else {
    const n = parseInt(key.replace('mes',''));
    const ini = new Date(hoy.getFullYear(), hoy.getMonth()-n, 1);
    const fin = new Date(hoy.getFullYear(), hoy.getMonth()-n+1, 0, 23,59,59,999);
    const nombres = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    return { ini, fin, label: nombres[ini.getMonth()] + ' ' + ini.getFullYear() };
  }
}

function getPzPeriodo(rango) {
  const desp = Object.values(pedidosAgrupados||{}).filter(p => p.estado === 'Despachado');
  return desp.filter(p => {
    const fRaw = p.fechaCompromiso || p.fechaPedido;
    if (!fRaw) return false;
    let f = fRaw instanceof Date ? fRaw : null;
    if (!f) {
      const parts = String(fRaw).split(/[-\/]/);
      if (parts.length === 3) {
        const a = parseInt(parts[0]), b = parseInt(parts[1]), c = parseInt(parts[2]);
        f = parts[0].length === 4 ? new Date(a,b-1,c) : c > 31 ? new Date(c,a-1,b) : new Date(c,b-1,a);
      }
    }
    return f && f >= rango.ini && f <= rango.fin;
  }).reduce((s,p) => s + (p.lineas||[]).reduce((a,l) => a + (l.cantPz||0), 0), 0);
}

function renderComparativo() {
  const keyA = (document.getElementById('compPeriodoA')||{}).value || 'mes0';
  const keyB = (document.getElementById('compPeriodoB')||{}).value || 'mes1';
  const rA = getPeriodoRango(keyA);
  const rB = getPeriodoRango(keyB);
  const pzA = getPzPeriodo(rA);
  const pzB = getPzPeriodo(rB);
  const diff  = pzA - pzB;
  const pct   = pzB > 0 ? Math.round((diff/pzB)*100) : pzA > 0 ? 100 : 0;
  const color = diff >= 0 ? '#2D5A1B' : '#C62828';
  const arrow = diff >= 0 ? '▲' : '▼';
  const el = document.getElementById('dashComparativo');
  if (!el) return;
  el.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-end;">
      <div>
        <div style="font-size:10px;color:#888;margin-bottom:1px;">${rA.label}</div>
        <div style="font-size:16px;font-weight:900;color:#1A1A1A;">${pzA.toLocaleString('es-MX')} pz</div>
      </div>
      <div style="font-size:18px;font-weight:900;color:${color};">${arrow}${Math.abs(pct)}%</div>
      <div style="text-align:right;">
        <div style="font-size:10px;color:#888;margin-bottom:1px;">${rB.label}</div>
        <div style="font-size:16px;font-weight:900;color:#aaa;">${pzB.toLocaleString('es-MX')} pz</div>
      </div>
    </div>
    <div style="font-size:10px;color:${color};margin-top:4px;text-align:center;font-weight:700;">${diff >= 0 ? '+' : ''}${diff.toLocaleString('es-MX')} piezas diferencia</div>`;
}

