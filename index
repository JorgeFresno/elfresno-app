      const regsEq   = mantRegistros.filter(r => String(r['IDEquipo']||r['Nombre']||'').trim() === String(e['ID']||e['Nombre']||'').trim());
      const correctivos = regsEq.filter(r => String(r['Tipo']||'').trim() === 'Correctivo').length;
