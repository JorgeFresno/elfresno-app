function renderUbicaciones() {
  const container = document.getElementById('ubicContainer');
  const q = (document.getElementById('ubicSearchInput')?.value || '').toLowerCase().trim();
  const filtroUbic = document.getElementById('ubicFiltroUbic')?.value || '';
  const skip = ['ClaveProducto','Descripcion','UnidadBase','Total_ubicaciones','Es_Pieza'];

  let lista = allUbicaciones.filter(p => {
    if (!p.clave) return false;
    if (q && !p.clave.toLowerCase().includes(q) && !p.descripcion.toLowerCase().includes(q)) return false;
    if (filtroUbic) {
      const stock = p.ubicaciones[filtroUbic] || 0;
      if (stock === 0) return false;
    }
    return true;
  });

  if (!lista.length) { container.innerHTML = '<div class="empty-state">Sin resultados</div>'; return; }

  // Get ubicacion columns to show
  const todasUbics = allUbicaciones.length > 0
    ? Object.keys(allUbicaciones[0].ubicaciones).filter(k => !skip.includes(k))
    : [];
  const ubicsConStock = filtroUbic ? [filtroUbic] :
    todasUbics.filter(u => lista.some(p => (p.ubicaciones[u] || 0) !== 0));

  container.innerHTML = lista.slice(0, 60).map(p => {
    const ubicsConValor = ubicsConStock.filter(u => (p.ubicaciones[u] || 0) !== 0);
    if (!ubicsConValor.length && !filtroUbic && q === '') return '';
    return `<div onclick="openProdDetalle('${p.clave}')" style="background:white;border-radius:12px;padding:12px;margin-bottom:8px;border:1px solid var(--border);cursor:pointer;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;"><div style="font-weight:700;font-size:13px;color:var(--green-dark);">${p.clave}</div><div style="font-size:11px;color:#aaa;">Ver detalle ›</div></div>
      <div style="font-size:11px;color:#666;margin-bottom:6px;">${p.descripcion}</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        ${ubicsConValor.map(u => {
          const val = p.ubicaciones[u] || 0;
          const color = val > 0 ? '#E8F5E9' : '#FFF3E0';
          const textColor = val > 0 ? '#2D5A1B' : '#E65100';
          return `<div style="background:${color};border-radius:8px;padding:4px 8px;font-size:11px;">
            <span style="color:#666;">${u}:</span> <strong style="color:${textColor};">${val.toLocaleString('es-MX')} ${p.unidad||''}</strong>
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }).filter(Boolean).join('');
}

