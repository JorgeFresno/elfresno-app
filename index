function renderMantPreventivos(container) {
  const preventivos = mantRegistros.filter(r => String(r['Tipo']||'Preventivo').trim() !== 'Correctivo')
    .sort((a, b) => new Date(b['Fecha']) - new Date(a['Fecha']));
  if (!preventivos.length) { container.innerHTML = '<div class="empty-state">Sin preventivos registrados</div>'; return; }
  container.innerHTML = preventivos.map(r => renderRegistroCard(r)).join('');
}

function renderMantCorrectivos(container) {
  const correctivos = mantRegistros.filter(r => String(r['Tipo']||'').trim() === 'Correctivo')
    .sort((a, b) => new Date(b['Fecha']) - new Date(a['Fecha']));
  if (!correctivos.length) { container.innerHTML = '<div class="empty-state">Sin correctivos registrados</div>'; return; }
  container.innerHTML = correctivos.map(r => renderRegistroCard(r)).join('');
}

function renderMantHistorial(container) {
  const todos = [...mantRegistros].sort((a, b) => new Date(b['Fecha']) - new Date(a['Fecha']));
  if (!todos.length) { container.innerHTML = '<div class="empty-state">Sin registros aún</div>'; return; }
