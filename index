async function sincronizarMantenimiento() {
  const btn = document.getElementById('btnSyncMant');
  if (btn) { btn.disabled = true; btn.textContent = '⏳'; }

  try {
    const [tabEq, tabReg] = await Promise.all([
      fetchSheet('Mant_Equipos',   true).catch(() => null),
      fetchSheet('Mant_Registros', true).catch(() => null)
    ]);

    mantEquipos   = tabEq  ? tableToObjects(fixFirstHeader(tabEq,  'ID'))   : [];
    mantRegistros = tabReg ? tableToObjects(fixFirstHeader(tabReg,  'ID'))   : [];

    // Filtrar solo activos
    mantEquipos = mantEquipos.filter(e => String(e['Activo']||'SI').toUpperCase() === 'SI');

