    const fixed = fixFirstHeader(table, 'ClaveProducto');
    const rows  = tableToObjects(fixed);
    const skip  = ['ClaveProducto','Descripcion','UnidadBase','Total_ubicaciones','Es_Pieza',''];
    allUbicaciones = rows.map(r => {
      const ubics = {};
      Object.keys(r).forEach(k => {
        if (!skip.includes(k.trim())) ubics[k] = parseFloat(r[k] || 0);
      });
      return {
        clave:       String(r['ClaveProducto'] || '').trim(),
        descripcion: String(r['Descripcion']   || '').trim(),
        unidad:      String(r['UnidadBase']    || '').trim(),
        ubicaciones: ubics
      };
    }).filter(r => r.clave);
