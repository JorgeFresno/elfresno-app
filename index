function actualizarResumenRecepcion() {
  if (!camiones.length) return;
  const totalBruto = camiones.reduce((s, c) => s + (c.kgBruto||0), 0);
  const totalTara  = camiones.reduce((s, c) => s + (c.kgTara||0), 0);
  const totalNeto  = camiones.reduce((s, c) => s + (c.kgNeto||0), 0);
  document.getElementById('resumenCamiones').textContent = camiones.length;
  document.getElementById('resumenBruto').textContent = totalBruto.toLocaleString('es-MX');
  document.getElementById('resumenTara').textContent  = totalTara.toLocaleString('es-MX');
  document.getElementById('resumenNeto').textContent  = totalNeto.toLocaleString('es-MX');
  document.getElementById('recepcionResumen').style.display = 'block';
}

