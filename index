function calcMaqAcond() {
  const kg     = parseFloat(document.getElementById('maqAKgAcond')?.value) || 0;
  const bultos = Math.floor(kg / 25);
  const prodOK = maqProduccionData.filter(p => p['Estado'] !== 'Cancelado');
  const totalBultosAntes = prodOK.reduce((s, p) => s + (parseFloat(p['BultosAcondicionados']) || 0), 0);
  const folioIni = totalBultosAntes + 1;
  const folioFin = totalBultosAntes + bultos;
  const pad = n => String(n).padStart(4, '0');
  document.getElementById('maqABultosCalc').textContent = bultos > 0 ? bultos : '0';
  document.getElementById('maqAFoliosCalc').textContent = bultos > 0 ? pad(folioIni) + '—' + pad(folioFin) : '0001—0000';
}

