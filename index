function generarTicketMovimiento(idx) {
  const m = allMovimientos[idx];
  if (!m) return;

  const folio    = m['FolioMov'] || m['DocumentoRef'] || '—';
  const tipo     = m['TipoMov'] || '—';
  const clave    = m['ClaveProducto'] || '—';
  const desc     = m['Descripcion'] || clave;
  const cantPz   = parseFloat(m['CantidadPz'] || 0);
  const cantKg   = parseFloat(m['CantidadKg'] || 0);
  const origen   = m['UbicacionOrigen'] || '—';
  const destino  = m['UbicacionDestino'] || '—';
  const captura  = m['Captura'] || '—';
  const cliente  = m['Cliente'] || m['Proveedor'] || '';
  const docRef   = m['DocumentoRef'] || '—';
  const obs      = m['Observaciones'] || '';
  const estado   = m['Estado'] || '—';

  // Formatear fecha
  let fechaStr = '—';
  const fv = m['FechaMov'];
