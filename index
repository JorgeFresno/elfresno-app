async function guardarUsuario() {
  const id     = document.getElementById('ufId').value.trim();
  const nombre = document.getElementById('ufNombre').value.trim();
  const pass   = document.getElementById('ufPass').value.trim();
  const rol    = document.getElementById('ufRol').value;
  const activo = document.getElementById('ufActivo').checked ? 'SI' : 'NO';
  const errDiv = document.getElementById('ufError');

  if (!nombre || !pass) {
    errDiv.textContent = 'Nombre y contraseña son obligatorios';
    errDiv.style.display = 'block';
    return;
  }

  const esNuevo  = !id;
  const nuevoId  = esNuevo ? generarSiguienteId() : id;
  const fila     = [nuevoId, nombre, pass, rol, activo];

  try {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        accion: esNuevo ? 'agregarUsuario' : 'editarUsuario',
        id:     nuevoId,
        fila:   fila
      })
    });

    // Actualizar lista local
    if (esNuevo) {
      allUsuarios.push({ id: nuevoId, nombre, pass, rol, activo: activo === 'SI' });
    } else {
      const idx = allUsuarios.findIndex(function(u){ return u.id === id; });
      if (idx >= 0) allUsuarios[idx] = { id, nombre, pass, rol, activo: activo === 'SI' };
    }

    cerrarModal('usuarioFormOverlay');
    renderUsuariosList();
    document.getElementById('usuariosCount').textContent = allUsuarios.length + ' usuarios';
    showToast('✅ Usuario ' + (esNuevo ? 'creado' : 'actualizado') + ' — sync en 2s', 'success');
  } catch(e) {
    errDiv.textContent = 'Error al guardar — verifica conexión';
    errDiv.style.display = 'block';
  }
}

