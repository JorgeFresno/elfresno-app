let allProducts = [];
let allMovimientos = [];

// ── NAVEGACIÓN SIMPLE ──
function abrirModal(id) {
  document.getElementById(id).classList.add('open');
}

function cerrarModal(id) {
  document.getElementById(id).classList.remove('open');
  // Restaurar scroll del body si no hay otros modales abiertos
  const hayAbierto = document.querySelector('.modal-overlay.open, #ticketOverlay.open, #modalOverlay.open');
  if (!hayAbierto) document.body.style.overflow = '';
}

function abrirModal(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}

// Atrás con destino explícito: cierra actual y abre anterior
function goBack(idActual, idAnterior) {
  document.getElementById(idActual).classList.remove('open');
  if (idAnterior) {
    document.getElementById(idAnterior).classList.add('open');
    document.body.style.overflow = 'hidden';
  } else {
    document.body.style.overflow = '';
  }
}
let allProveedores = [];
let allClientes = [];
let allPedidosRaw = [];        // filas crudas de Agenda_Pedidos
let pedidosAgrupados = {};     // agrupados por PedidoRQF
let currentFilter = 'todos';
let currentAgendaFilter = 'todos';
let lastSync = null;
let selectedTipo = '';
let selectedProducto = null;
let npLineasCount = 0;

// ==========================================
//  UTILS
// ==========================================
function generateMovId() {
  return 'mid_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
}

function formatNum(n) {
  if (n === null || n === undefined || n === '') return '—';
  const num = Number(n);
  if (isNaN(num)) return '—';
  return num.toLocaleString('es-MX', { maximumFractionDigits: 1 });
}

function formatDate(v) {
  if (!v) return '—';
  if (typeof v === 'string' && v.startsWith('Date(')) {
    const parts = v.replace('Date(','').replace(')','').split(',').map(Number);
    return `${String(parts[2]).padStart(2,'0')}/${String(parts[1]+1).padStart(2,'0')}/${parts[0]}`;
  }
  if (typeof v === 'string' && v.includes('-')) {
    const [y,m,d] = v.split('-');
    return `${d}/${m}/${y}`;
  }
  return String(v);
}

function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + (type==='success'?'success':type==='error'?'error-toast':'');
  setTimeout(() => t.className = 'toast', 3000);
}

// ==========================================
//  SHEETS FETCH
// ==========================================
async function fetchSheet(sheetName, bustCache = false) {
  const cb  = bustCache ? '&_=' + Date.now() : '';
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(sheetName)}${cb}`;
  const res = await fetch(url, { cache: 'no-store' });
  const text = await res.text();
  const json = JSON.parse(text.substring(47).slice(0, -2));
  return json.table;
}

function tableToObjects(table) {
  if (!table || !table.rows) return [];
  const allHeaders = table.cols.map(c => c.label || '');
  const firstNonEmpty = allHeaders.findIndex(h => h.trim() !== '');
  return table.rows
    .filter(row => {
      if (!row || !row.c) return false;
      const cell = row.c[firstNonEmpty >= 0 ? firstNonEmpty : 0];
      return cell && cell.v !== null && cell.v !== '' && String(cell.v).trim() !== '';
    })
    .map(row => {
      const obj = {};
      allHeaders.forEach((h, i) => {
        if (h.trim()) obj[h] = row.c[i] ? (row.c[i].v !== null ? row.c[i].v : '') : '';
      });
      return obj;
    });
}

function fixFirstHeader(table, fallback) {
  if (!table || !table.cols) return table;
  table.cols = table.cols.map((col, i) => {
    if (i === 0) {
      const parts = (col.label || '').trim().split(/\s+/);
      col.label = parts[parts.length - 1] || fallback || col.id;
    }
    return col;
  });
  return table;
}

