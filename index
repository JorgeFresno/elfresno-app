function buscarOperador(id, q) {
  updateCamion(id, 'chofer', q);
  const sugBox = document.getElementById('choferSug_' + id);
  if (!sugBox) return;
  if (!q.trim()) { sugBox.style.display = 'none'; return; }
  const matches = catOperadores.filter(o => o.toLowerCase().includes(q.toLowerCase())).slice(0, 6);
  if (!matches.length) { sugBox.style.display = 'none'; return; }
  sugBox.innerHTML = matches.map(o =>
    `<div style="padding:8px 12px;font-size:12px;cursor:pointer;border-bottom:1px solid #f0f0f0;"
      onmousedown="selectOperador(${id},'${o.replace(/'/g,"\'")}');event.preventDefault();">${o}</div>`
  ).join('');
  sugBox.style.display = 'block';
}

function selectOperador(id, nombre) {
  updateCamion(id, 'chofer', nombre);
  const input = document.getElementById('choferInput_' + id);
  if (input) input.value = nombre;
  const sugBox = document.getElementById('choferSug_' + id);
  if (sugBox) sugBox.style.display = 'none';
}

function toggleClearCamion(input) {
  const btn = input.nextElementSibling;
  if (btn && btn.tagName === 'BUTTON') btn.style.display = input.value ? 'flex' : 'none';
}

function clearCamionField(id, field, btn) {
  updateCamion(id, field, '');
  if (btn) btn.style.display = 'none';
}

function updateCamion(id, field, value) {
  const c = camiones.find(c => c.id === id);
  if (c) c[field] = value;
}

function updateCamionKg(id, field, value) {
  const c = camiones.find(c => c.id === id);
  if (!c) return;
  c[field] = parseFloat(value) || 0;
  c.kgNeto = Math.max(0, (c.kgBruto || 0) - (c.kgTara || 0));
  // Actualizar solo el kgNeto en el DOM sin re-renderizar (para no perder foco)
  const netoEl = document.getElementById('kgNeto_' + id);
  if (netoEl) netoEl.textContent = c.kgNeto.toLocaleString('es-MX');
  actualizarResumenRecepcion();
}

function buscarOperadorCamion(id, q) {
  updateCamion(id, 'chofer', q);
  const sug = document.getElementById('choferSug_' + id);
  if (!sug) return;
  if (!q || q.length < 1) { sug.style.display = 'none'; return; }
  const matches = (catOperadores || []).filter(o => o.toLowerCase().includes(q.toLowerCase())).slice(0, 6);
  if (!matches.length) { sug.style.display = 'none'; return; }
  sug.innerHTML = matches.map(o =>
    `<div onclick="selectOperadorCamion(${id},'${o.replace(/'/g,"&#39;")}')"
      style="padding:10px 12px;font-size:13px;cursor:pointer;border-bottom:1px solid #f0f0f0;"
      onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background=''">${o}</div>`
  ).join('');
  sug.style.display = 'block';
}

function selectOperadorCamion(id, nombre) {
  updateCamion(id, 'chofer', nombre);
