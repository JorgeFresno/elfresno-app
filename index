  const paquetes    = parseFloat(document.getElementById('prodPaquetes').value) || 0;
  const tarimas     = parseFloat(document.getElementById('prodTarimas').value) || 0;
  const kgProd      = parseFloat(document.getElementById('prodKgProd').value) || 0;
  const kgCons      = parseFloat(document.getElementById('prodKgCons').value) || 0;

  // Validaciones
  if (!fecha)       { showToast('❌ Falta la fecha', 'error'); return; }
  if (!granelClave) { showToast('❌ Selecciona el granel origen', 'error'); return; }
  if (!ubicOrigen)  { showToast('❌ Selecciona la tolva origen', 'error'); return; }
  if (!ptClave)     { showToast('❌ Selecciona el producto terminado', 'error'); return; }
  if (piezas <= 0)  { showToast('❌ Captura las piezas producidas', 'error'); return; }
  if (kgCons <= 0)  { showToast('❌ Captura los kg consumidos', 'error'); return; }

  const granelProd  = allProducts.find(p => p.clave === granelClave);
  const ptProd      = allProducts.find(p => p.clave === ptClave);
  const folioNum    = String(allProd.length + 1).padStart(6, '0');
  const idprod      = 'PROD-' + folioNum;

  // Fecha formateada DD/MM/YYYY
  const [y, m, d] = fecha.split('-');
  const fechaFmt = d + '/' + m + '/' + y;

  showToast('⏳ Registrando producción...', '');

  try {
    const resp = await fetch(APPS_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        accion:           'guardarProduccion',
        Fecha:            fechaFmt,
        Usuario:          currentUser?.id || 'U01',
        ClaveGranelOrigen:  granelClave,
        ProductoGranelOrigen: granelProd?.nombre || granelClave,
        ClaveProductoTerminado: ptClave,
        ProductoTerminado: ptProd?.nombre || ptClave,
        Gramaje:          ptProd?.gramaje || '',
        LoteCaducidad:    lote,
        UbicacionOrigen:  ubicOrigen,
        UbicacionDestino: ubicDest,
        Piezas:           piezas,
        Paquetes:         paquetes,
        Tarimas:          tarimas,
        KgProducidos:     kgProd,
        KgConsumidosGranel: kgCons,
        FolioMaquila:     folioMaq,
        Observaciones:    obs,
        Estado:           'OK',
        Personal:         personal,
        IDPROD:           idprod
      })
    });

    // Con no-cors no podemos leer respuesta, pero si llegamos aquí sin excepción el POST se envió
    allProd.push({
      IDPROD: idprod,
      Fecha: fechaFmt,
      ClaveProductoTerminado: ptClave,
      ProductoTerminado: ptProd?.nombre || ptClave,
      ClaveGranelOrigen: granelClave,
      ProductoGranelOrigen: granelProd?.nombre || granelClave,
      Piezas: piezas,
      KgProducidos: kgProd,
      KgConsumidosGranel: kgCons,
      UbicacionOrigen: ubicOrigen,
      UbicacionDestino: ubicDest,
      Personal: personal,
      Estado: 'OK'
    });

    showToast('✅ ' + idprod + ' enviado — verifica en Sheets', 'success');

    // Resetear form
    document.getElementById('prodPiezas').value   = '';
    document.getElementById('prodPaquetes').value = '';
    document.getElementById('prodTarimas').value  = '';
    document.getElementById('prodKgProd').value   = '';
    document.getElementById('prodKgCons').value   = '';
    document.getElementById('prodLote').value     = '';
    document.getElementById('prodObs').value      = '';
    document.getElementById('prodFolioMaquila').value = '';
    document.getElementById('prodGranelSearch').value = '';
    document.getElementById('prodGranelOrigen').value = '';
    document.getElementById('prodPTSearch').value = '';
    document.getElementById('prodPTOrigen').value = '';
    document.getElementById('prodStockUbicBadge').style.display = 'none';

    // Actualizar folio
    const newNum = String(allProd.length + 1).padStart(6, '0');
    document.getElementById('prodFolioBadge').textContent = '🏭 PROD-' + newNum;

    // Recargar datos
    setTimeout(() => syncData(), 2000);

  } catch(e) {
    showToast('❌ Error al registrar', 'error');
    console.error(e);
  }
}

