function getDiasDesdeUltimoMant(equipo) {
  const registrosEquipo = mantRegistros.filter(r =>
    String(r['IDEquipo'] || r['Nombre'] || '').trim() === String(equipo['ID'] || equipo['Nombre'] || '').trim() &&
    String(r['Estado'] || '').trim() !== 'Cancelado'
  );
  if (!registrosEquipo.length) return 9999; // nunca mantenido

  const fechas = registrosEquipo
    .map(r => new Date(r['Fecha']))
    .filter(d => !isNaN(d));
  if (!fechas.length) return 9999;

  const ultima = new Date(Math.max(...fechas));
  const hoy    = new Date();
  return Math.floor((hoy - ultima) / (1000 * 60 * 60 * 24));
}

function getMantSemaforo(equipo) {
  const dias       = getDiasDesdeUltimoMant(equipo);
  const periodo    = parseInt(equipo['Periodo_Dias']) || 90;
  const pct        = dias / periodo;
  if (dias === 9999) return { estado: 'sinregistro', color: '#888',    bg: '#F5F5F5', label: 'Sin registro', emoji: '⚪' };
  if (pct >= 1)      return { estado: 'vencido',     color: '#C62828', bg: '#FDECEA', label: 'Vencido',      emoji: '🔴' };
  if (pct >= 0.85)   return { estado: 'proximo',     color: '#E65100', bg: '#FFF3E0', label: 'Próximo',      emoji: '🟡' };
  return               { estado: 'aldia',            color: '#2D5A1B', bg: '#E8F5E9', label: 'Al día',        emoji: '🟢' };
}

function renderMantenimiento() {
  const container = document.getElementById('mantContenido');
  if (!container || !mantEquipos.length) {
    if (container) container.innerHTML = '<div class="empty-state">Sin equipos registrados</div>';
    return;
  }

  // KPIs
  let vencidos = 0, proximos = 0;
  mantEquipos.forEach(e => {
    const s = getMantSemaforo(e);
    if (s.estado === 'vencido')  vencidos++;
    if (s.estado === 'proximo')  proximos++;
  });
  const elV = document.getElementById('mantKpiVencidos');
  const elP = document.getElementById('mantKpiProximos');
  const elT = document.getElementById('mantKpiTotal');
  if (elV) elV.textContent = vencidos;
  if (elP) elP.textContent = proximos;
  if (elT) elT.textContent = mantEquipos.length;

  if (mantTabActual === 'maquinas')    renderMantMaquinas(container);
  else if (mantTabActual === 'preventivos') renderMantPreventivos(container);
  else if (mantTabActual === 'correctivos') renderMantCorrectivos(container);
  else if (mantTabActual === 'historial')   renderMantHistorial(container);
}

