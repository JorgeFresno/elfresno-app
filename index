<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>El Fresno – Acceso</title>
  <style>
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto;display:flex;align-items:center;justify-content:center;height:100vh;background:#0f172a;color:#e5e7eb;margin:0}
    .card{background:#111827;border:1px solid #1f2937;border-radius:16px;padding:24px;width:320px;box-shadow:0 10px 30px rgba(0,0,0,.4)}
    h1{margin:0 0 12px 0;font-size:20px}
    input,button{width:100%;padding:10px;border-radius:10px;border:1px solid #374151;background:#020617;color:#e5e7eb;margin-top:10px}
    button{background:#2563eb;border:none;font-weight:700;cursor:pointer}
    .err{color:#fca5a5;margin-top:8px;font-size:12px}
  </style>
</head>
<body>
  <div class="card">
    <h1>El Fresno</h1>
    <input id="u" placeholder="Usuario" />
    <input id="p" type="password" placeholder="Contraseña" />
    <button onclick="login()">Entrar</button>
    <div id="msg" class="err"></div>
  </div>

<script>
  // 👉 PON AQUÍ TU URL DE APPS SCRIPT (la que sí responde "El Fresno API activa")
  const API = "https://script.google.com/macros/s/AKfycbx28vAEwwwli7NufRz-iw2aKfLFKqhB-4HCHXvJq25IcOnkzp8_-dXoliZ3QG9tfxWw/exec";

  async function login(){
    const u = document.getElementById('u').value.trim();
    const p = document.getElementById('p').value.trim();
    const msg = document.getElementById('msg');
    msg.textContent = '';

    try{
      const resp = await fetch(API, {
        method:'POST',
        headers:{'Content-Type':'text/plain'},
        body: JSON.stringify({accion:'login', usuario:u, password:p})
      });
      const txt = await resp.text();
      let data = {};
      try{ data = JSON.parse(txt); }catch{ throw new Error('Respuesta inválida'); }

      if(!data.ok){ throw new Error(data.error || 'Login inválido'); }

      // guarda sesión simple
      localStorage.setItem('usuario', u);

      // 👉 redirige a una pantalla simple (no rompemos nada)
      window.location.href = 'home.html';
    }catch(e){
      msg.textContent = 'Error: ' + e.message;
    }
  }
</script>
</body>
</html>
