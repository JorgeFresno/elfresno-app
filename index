// ── FORMULARIOS DE CAPTURA ────────────────────────────────────

function calcPesoNetoMaq() {
  const bruto = parseFloat(document.getElementById('maqEBruto')?.value) || 0;
  const tara  = parseFloat(document.getElementById('maqETara')?.value)  || 0;
  const neto  = Math.max(0, bruto - tara);
  const el    = document.getElementById('maqEPesoNeto');
  if (el) el.textContent = formatNum(neto) + ' kg';
}

function abrirFormEntradaMaquila() {
  if (!maqDetalleActual) return;
  const hoy = new Date().toISOString().split('T')[0];
  ['maqEChofer','maqETolvaViaje','maqETicket','maqEObs'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  ['maqEBultos','maqEBruto','maqEPesoProveedor','maqEPesoDoc'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  document.getElementById('maqEFecha').value = hoy;

  // Peso documentado solo visible en Acondicionamiento
  const esAcond = (maqDetalleActual.Tipo || '').toLowerCase().includes('acondicionamiento')
    || (maqDetalleActual.Folio || '').toLowerCase().includes('agcyr')
    || (maqDetalleActual.Folio || '').toLowerCase().includes('fito');
  const docInput = document.getElementById('maqEPesoDoc');
  const docLabel = document.getElementById('maqEPesoDocLabel');
  if (docInput) docInput.style.display = esAcond ? '' : 'none';
  if (docLabel) docLabel.style.display = esAcond ? '' : 'none';

  abrirModal('maqEntradaOverlay');
}

async function guardarEntradaMaquila() {
  const kgFresno = parseFloat(document.getElementById('maqEBruto')?.value) || 0;
  const ticket   = document.getElementById('maqETicket')?.value.trim() || '';
  if (!kgFresno) { showToast('KG Fresno requerido', 'error'); return; }
  if (!ticket)   { showToast('Ticket requerido', 'error'); return; }

  // Anti-duplicados
  const btn = document.getElementById('btnGuardarEntrada');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span>Guardando...';

  const acta   = maqDetalleActual.Folio;
  const movId  = 'MAQ-' + Date.now() + '-' + Math.random().toString(36).substr(2,5);
  const chofer = document.getElementById('maqEChofer')?.value.trim() || '';
  const obs    = document.getElementById('maqEObs')?.value.trim() || '';

  const pesoProveedor = parseFloat(document.getElementById('maqEPesoProveedor')?.value) || 0;
  const pesoDoc       = parseFloat(document.getElementById('maqEPesoDoc')?.value) || 0;

  const camion = {
    Acta:            acta,
    Fecha:           document.getElementById('maqEFecha')?.value || '',
    NumCamion:       document.getElementById('maqETolvaViaje')?.value.trim() || '',
    TicketFresno:    ticket,
    KgFresno:        kgFresno,
    Bultos:          parseFloat(document.getElementById('maqEBultos')?.value) || 0,
    PesoProveedor:   pesoProveedor,
    PesoDocumentado: pesoDoc,
    Observaciones:   [chofer ? 'Chofer: ' + chofer : '', obs].filter(Boolean).join(' | '),
    movId:           movId
  };

  try {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({ accion: 'guardarRecepcionMaquila', Acta: acta, camiones: [camion] })
    });
    maqEntradasData.push(camion);
    actualizarKpisMaqDet();
    cerrarModal('maqEntradaOverlay');
    renderMaqDetTab('entradas');
    showToast('✅ Camión registrado · ' + formatNum(kgFresno) + ' kg', 'success');
    setTimeout(() => cargarDatosMaquilaDetalle(maqDetalleActual?.Folio || '', true), 4000);
  } catch(e) {
    showToast('❌ Error al guardar', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '✓ Registrar entrada';
  }
}

async function cancelarEntradaMaquila(idx) {
  const e = maqEntradasData[idx];
  if (!e) return;
  if (e['Estado'] === 'Cancelado' || e._cancelado) {
    showToast('Ya está cancelada', ''); return;
  }
  const ticket = e['TicketFresno'] || 'Camión ' + (idx + 1);
  const kg     = formatNum(parseFloat(e['KgFresno']) || 0);
  if (!confirm('¿Cancelar entrada ' + ticket + ' · ' + kg + ' kg?\nSe quitarán del total recibido.')) return;

  // Marcar localmente de inmediato
  maqEntradasData[idx]['Estado']    = 'Cancelado';
  maqEntradasData[idx]._cancelado   = true;
  actualizarKpisMaqDet();
  renderMaqDetTab('entradas');
  showToast('Entrada ' + ticket + ' cancelada', 'success');

  // Persistir en Sheets
  try {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        accion:       'cancelarEntradaMaquila',
        Acta:         maqDetalleActual.Folio,
        TicketFresno: e['TicketFresno'] || ''
      })
    });
  } catch(err) {
    console.error('cancelarEntradaMaquila:', err);
  }
}

