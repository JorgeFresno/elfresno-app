async function guardarNuevaOrdenMaquila() {
  const cliente  = document.getElementById('maqCliente')?.value.trim();
  const tipo     = document.getElementById('maqTipo')?.value;
  const producto = document.getElementById('maqProducto')?.value.trim();
  const actaInput = (document.getElementById('maqActa')?.value || '').trim();

  if (!cliente || !tipo || !producto) {
    showToast('Cliente, tipo y producto son requeridos', 'error');
    return;
  }

  // Acta: obligatoria solo para Acondicionamiento, opcional para el resto
  if (tipo === 'Acondicionamiento' && !actaInput) {
    showToast('El Acta es requerida para Acondicionamiento', 'error');
    return;
  }

  // Si no hay Acta, generar folio interno MQ-YYYY-NNN
  let folioMaestro = actaInput;
  if (!folioMaestro) {
    const year = new Date().getFullYear();
    const nums = allOrdenesMAQ
      .map(o => { const m = String(o.Folio).match(/MQ-\d{4}-(\d+)/); return m ? parseInt(m[1]) : 0; })
      .filter(n => n > 0);
    const siguiente = nums.length ? Math.max(...nums) + 1 : 1;
    folioMaestro = 'MQ-' + year + '-' + String(siguiente).padStart(3, '0');
  }

  const payload = {
    accion:            'guardarOrdenMaquila',
    Acta:              folioMaestro,
    Cliente:           cliente,
    FechaLlegada:      new Date().toLocaleDateString('es-MX'),
    TolvaFurgon:       '',
    BultosTotal:       0,
    KgTotal:           0,
    CertInternacional: '',
    CertFitosanitario: '',
    NumCertificado:    '',
    PesoDocumentado:   0,
    CambiaCostal:      'No',
    GramosCostal:      0,
    Estatus:           'En proceso',
    URLDrive:          document.getElementById('maqHojaCliente')?.value.trim() || '',
    Observaciones:     document.getElementById('maqObservaciones')?.value.trim() || ''
  };

  const labelFolio = actaInput ? 'Acta ' + folioMaestro : 'Orden ' + folioMaestro;

  try {
    const resp = await fetch(APPS_SCRIPT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify(payload)
    });
    const data = await resp.json();
    if (data.ok) {
      showToast('✅ ' + labelFolio + ' creada', 'success');
      cerrarModal('nuevaMaquilaOverlay');
      await sincronizarMaquilas();
    } else {
      showToast('Error: ' + (data.mensaje || 'desconocido'), 'error');
    }
  } catch(e) {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify(payload)
    });
    showToast('✅ ' + labelFolio + ' enviada — sincroniza para confirmar', 'success');
    cerrarModal('nuevaMaquilaOverlay');
    setTimeout(() => sincronizarMaquilas(), 2000);
  }
}

