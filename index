<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>El Fresno — Sistema de Gestión</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="El Fresno">
<meta name="theme-color" content="#2D5A1B">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<link rel="manifest" href="manifest.json">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --green-dark: #2D5A1B;
    --green-mid: #3D7A26;
    --green-light: #5BA33A;
    --green-pale: #EAF4E3;
    --green-accent: #7BC950;
    --red: #E53935;
    --red-pale: #FDECEA;
    --orange: #F57C00;
    --orange-pale: #FFF3E0;
    --blue: #1565C0;
    --blue-pale: #E3F2FD;
    --purple: #6A1B9A;
    --purple-pale: #F3E5F5;
    --text-primary: #1A1A1A;
    --text-secondary: #666;
    --text-muted: #999;
    --bg: #F5F5F5;
    --card: #FFFFFF;
    --border: #E8E8E8;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); max-width: 430px; margin: 0 auto; min-height: 100vh; overflow-x: hidden; }

  /* ── DESKTOP LAYOUT ── */
  @media (min-width: 900px) {
    body {
      max-width: 100% !important;
      margin: 0 !important;
      background: #E8EDE4;
    }

    /* Sidebar nav */
    .bottom-nav {
      position: fixed !important;
      top: 0; left: 0; bottom: 0;
      width: 220px !important;
      max-width: 220px !important;
      display: flex !important;
      flex-direction: column !important;
      grid-template-columns: unset !important;
      padding: 0 !important;
      border-top: none !important;
      border-right: 1.5px solid var(--border);
      background: white;
      z-index: 200;
      box-shadow: 2px 0 12px rgba(0,0,0,0.07);
      overflow-y: auto;
      transform: none !important;
      left: 0 !important;
    }
    .nav-item {
      flex-direction: row !important;
      gap: 12px !important;
      padding: 14px 20px !important;
      justify-content: flex-start !important;
      border-radius: 0 !important;
      width: 100% !important;
      box-sizing: border-box;
    }
    .nav-item:hover { background: #F5FAF3; }
    .nav-item.active { background: #EBF5E6 !important; border-left: 4px solid var(--green-dark); }
    .nav-item.active .nav-label { color: var(--green-dark) !important; }
    .nav-icon { font-size: 18px !important; min-width: 22px; text-align: center; }
    .nav-label { font-size: 13px !important; font-weight: 600 !important; }
    .nav-badge { position: static !important; margin-left: auto !important; }
    .nav-logo-desktop { display: flex !important; }

    /* Content area - pushed right of sidebar */
    .header {
      position: fixed !important;
      top: 0; left: 220px; right: 0;
      z-index: 150;
      max-width: none !important;
    }
    .page {
      margin-left: 220px;
      margin-top: 70px;
      min-height: 100vh;
      background: white;
      max-width: none !important;
    }
    .content { max-width: 720px; margin: 0 auto; }

    /* Modals centered */
    .modal-overlay { align-items: center; padding: 24px; }
    .modal-sheet { border-radius: 20px; max-width: 540px; margin: 0 auto; }
    .ticket-overlay { align-items: center; padding: 24px; }
    .ticket-container { border-radius: 20px; max-width: 360px; margin: 0 auto; }
  }
  
  /* HEADER */
  .header { background: var(--green-dark); padding: 16px 20px 14px; position: sticky; top: 0; z-index: 100; }
  .header-top { display: flex; align-items: center; justify-content: space-between; }
  .header-brand { display: flex; align-items: center; gap: 10px; }
  .brand-icon { width: 38px; height: 38px; background: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
  .brand-text h1 { font-size: 16px; font-weight: 700; color: white; line-height: 1.1; }
  .brand-text p { font-size: 11px; color: rgba(255,255,255,0.7); }
  .header-right { display: flex; align-items: center; gap: 10px; }
  .sync-btn { background: rgba(255,255,255,0.15); border: none; border-radius: 8px; padding: 6px 10px; color: white; font-size: 12px; cursor: pointer; font-family: 'DM Sans', sans-serif; display: flex; align-items: center; gap: 4px; transition: background 0.15s; }
  .sync-btn:active { background: rgba(255,255,255,0.25); }
  .avatar { width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.4); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: white; }
  
  /* LAYOUT */
  .content { padding: 16px 16px 110px; display: flex; flex-direction: column; gap: 14px; }
  .page { display: none; animation: fadeIn 0.2s ease; }
  .page.active { display: block; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  
  /* WELCOME */
  .welcome-card { background: linear-gradient(135deg, var(--green-mid) 0%, var(--green-light) 60%, var(--green-accent) 100%); border-radius: 20px; padding: 20px; color: white; position: relative; overflow: hidden; }
  .welcome-card::before { content: ''; position: absolute; top: -30px; right: -30px; width: 120px; height: 120px; background: rgba(255,255,255,0.08); border-radius: 50%; }
  .welcome-greeting { font-size: 13px; opacity: 0.85; margin-bottom: 2px; }
  .welcome-name { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
  .welcome-status { display: flex; align-items: center; gap: 6px; font-size: 12px; opacity: 0.8; margin-bottom: 16px; }
  .status-dot { width: 7px; height: 7px; background: #A8E063; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .welcome-divider { height: 1px; background: rgba(255,255,255,0.2); margin-bottom: 16px; }
  .welcome-kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .kpi { text-align: center; }
  .kpi-value { font-size: 22px; font-weight: 700; line-height: 1; }
  .kpi-label { font-size: 11px; opacity: 0.75; margin-top: 2px; }
  
  /* SECTION */
  .section-title { font-size: 11px; font-weight: 600; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; display: flex; align-items: center; gap: 6px; margin-bottom: -4px; }
  
  /* ACTION CARDS */
  .action-card { background: var(--card); border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 14px; cursor: pointer; transition: transform 0.15s; box-shadow: var(--shadow); border: 1px solid var(--border); }
  .action-card:active { transform: scale(0.98); }
  .action-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
  .action-body { flex: 1; }
  .action-title { font-size: 15px; font-weight: 600; }
  .action-sub { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
  .action-arrow { color: var(--text-muted); font-size: 16px; }
  .icon-green { background: var(--green-pale); }
  .icon-blue { background: #E3F2FD; }
  .icon-orange { background: #FFF3E0; }
  .icon-purple { background: #F3E5F5; }
  .icon-teal { background: #E0F2F1; }
  .icon-red { background: #FDECEA; }
  
  /* BOTTOM NAV */
  .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; width: 100%; background: white; border-top: 1px solid var(--border); display: flex; flex-direction: row; overflow-x: auto; overflow-y: hidden; padding: 6px 8px 20px; z-index: 100; gap: 4px; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .bottom-nav::-webkit-scrollbar { display: none; }
  .nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; padding: 6px 12px; position: relative; flex-shrink: 0; min-width: 64px; border-radius: 14px; transition: background 0.15s; }
  .nav-item:active { background: #f0f0f0; }
  .nav-icon { font-size: 24px; }
  .nav-label { font-size: 10px; font-weight: 600; color: var(--text-muted); letter-spacing: -0.01em; white-space: nowrap; }
  .nav-item.active .nav-label { color: var(--green-dark); font-weight: 700; }
  .nav-item.active .nav-icon { transform: scale(1.15); }
  .nav-badge { position: absolute; top: 2px; right: 10px; background: var(--red); color: white; border-radius: 10px; font-size: 9px; font-weight: 700; padding: 1px 5px; min-width: 16px; text-align: center; }
  
  /* INV SUMMARY */
  .inv-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .inv-kpi-card { background: var(--card); border-radius: 16px; padding: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); }
  .inv-kpi-icon { font-size: 24px; margin-bottom: 8px; }
  .inv-kpi-value { font-size: 24px; font-weight: 700; line-height: 1; }
  .inv-kpi-label { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }
  .inv-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-top: 6px; }
  .badge-green { background: #E8F5E9; color: #2E7D32; }
  .badge-orange { background: #FFF3E0; color: #E65100; }
  .badge-blue { background: #E3F2FD; color: #1565C0; }
  .badge-red { background: #FDECEA; color: #C62828; }
  
  /* FILTER TABS */
  .filter-tabs { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
  .filter-tabs::-webkit-scrollbar { display: none; }
  .filter-tab { flex-shrink: 0; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500; cursor: pointer; border: 1.5px solid var(--border); background: white; color: var(--text-secondary); transition: all 0.15s; }
  .filter-tab.active { background: var(--green-dark); border-color: var(--green-dark); color: white; }
  
  /* SEARCH BAR */
  .search-bar { background: white; border: 1.5px solid var(--border); border-radius: 12px; padding: 12px 16px; display: flex; align-items: center; gap: 10px; font-size: 14px; }
  .search-bar input { border: none; outline: none; flex: 1; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text-primary); background: transparent; }
  .search-bar input::placeholder { color: var(--text-muted); }
  
  /* PRODUCT CARDS */
  .product-card { background: var(--card); border-radius: 14px; padding: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); cursor: pointer; transition: transform 0.15s; }
  .product-card:active { transform: scale(0.99); }
  .product-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
  .product-name { font-size: 15px; font-weight: 600; }
  .product-code { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .status-chip { display: flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; flex-shrink: 0; }
  .chip-dot { width: 7px; height: 7px; border-radius: 50%; }
  .status-ok { background: #E8F5E9; color: #2E7D32; } .status-ok .chip-dot { background: #4CAF50; }
  .status-low { background: #FFF3E0; color: #E65100; } .status-low .chip-dot { background: #FF9800; }
  .status-critical { background: #FDECEA; color: #C62828; } .status-critical .chip-dot { background: var(--red); }
  .status-zero { background: #F5F5F5; color: #999; } .status-zero .chip-dot { background: #CCC; }
  .progress-bar { height: 6px; background: #EEE; border-radius: 3px; overflow: hidden; margin-bottom: 10px; }
  .progress-fill { height: 100%; border-radius: 3px; }
  .fill-green { background: linear-gradient(90deg,#4CAF50,#8BC34A); }
  .fill-orange { background: linear-gradient(90deg,#FF9800,#FFC107); }
  .fill-red { background: linear-gradient(90deg,#F44336,#E91E63); }
  .fill-gray { background: #CCC; }
  .product-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; }
  .stat { text-align: center; }
  .stat-value { font-size: 15px; font-weight: 700; }
  .stat-value.orange { color: var(--orange); }
  .stat-value.green { color: #4CAF50; }
  .stat-label { font-size: 10px; color: var(--text-muted); margin-top: 1px; }
  
  /* MOVIMIENTOS */
  .mov-summary { background: var(--card); border-radius: 16px; padding: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); display: grid; grid-template-columns: repeat(3,1fr); text-align: center; }
  .mov-stat-value { font-size: 24px; font-weight: 700; }
  .mov-stat-value.positive { color: #4CAF50; } .mov-stat-value.negative { color: var(--red); }
  .mov-stat-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .mov-divider { width: 1px; background: var(--border); align-self: stretch; }
  .mov-item { background: var(--card); border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; box-shadow: var(--shadow); border: 1px solid var(--border); cursor: pointer; transition: transform 0.15s; }
  .mov-item:active { transform: scale(0.99); }
  .mov-icon-wrap { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
  .mov-body { flex: 1; min-width: 0; }
  .mov-folio { font-size: 14px; font-weight: 600; font-family: 'DM Mono', monospace; }
  .mov-detail { font-size: 12px; color: var(--text-secondary); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mov-detail.cancelled { color: var(--red); font-weight: 500; }
  .mov-amount { text-align: right; flex-shrink: 0; }
  .mov-qty { font-size: 15px; font-weight: 700; }
  .mov-qty.positive { color: #4CAF50; } .mov-qty.negative { color: var(--red); }
  .mov-time { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  
  /* STATES */
  .loading-state { text-align: center; padding: 40px 20px; color: var(--text-muted); }
  .loading-spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--green-mid); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 12px; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .btn-spinner { display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:white;border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle;margin-right:6px;flex-shrink:0; }
  .btn-spinner-dark { display:inline-block;width:16px;height:16px;border:2px solid rgba(0,0,0,0.15);border-top-color:#2D5A1B;border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle;margin-right:6px;flex-shrink:0; }
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 14px; }
  .last-sync { font-size: 11px; color: var(--text-muted); text-align: center; padding: 4px 0; }
  
  /* ALERTS */
  .alert-card { border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; cursor: pointer; border-left: 4px solid transparent; }
  .alert-card.critical { background: var(--red-pale); border-left-color: var(--red); }
  .alert-card.warning { background: var(--orange-pale); border-left-color: var(--orange); }
  .alert-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .alert-dot.red { background: var(--red); } .alert-dot.orange { background: var(--orange); }
  .alert-body { flex: 1; }
  .alert-title { font-size: 14px; font-weight: 600; }
  .alert-title.red { color: var(--red); } .alert-title.orange { color: var(--orange); }
  .alert-sub { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }

  /* SCANNER */
  .scanner-area { background: #1A1A1A; border-radius: 20px; height: 280px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .corner-box { width: 200px; height: 160px; position: relative; }
  .corner-box::before,.corner-box::after,.corner-box>span::before,.corner-box>span::after { content:''; position:absolute; width:24px; height:24px; border-color:#7BC950; border-style:solid; }
  .corner-box::before { top:0;left:0;border-width:3px 0 0 3px;border-radius:3px 0 0 0; }
  .corner-box::after { top:0;right:0;border-width:3px 3px 0 0;border-radius:0 3px 0 0; }
  .corner-box>span::before { bottom:0;left:0;border-width:0 0 3px 3px;border-radius:0 0 0 3px; }
  .corner-box>span::after { bottom:0;right:0;border-width:0 3px 3px 0;border-radius:0 0 3px 0; }
  .scan-line { position:absolute; width:180px; height:2px; background:linear-gradient(90deg,transparent,#7BC950,transparent); animation:scanMove 2s ease-in-out infinite; }
  @keyframes scanMove { 0%,100%{top:25%} 50%{top:65%} }
  .scanner-hint { position:absolute; bottom:16px; color:rgba(255,255,255,0.6); font-size:13px; }
  .scan-btn { background:linear-gradient(135deg,var(--green-mid),var(--green-light)); color:white; border:none; border-radius:14px; padding:16px; font-size:15px; font-weight:600; width:100%; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; font-family:'DM Sans',sans-serif; }
  .scan-btn-secondary { background:white; color:var(--text-primary); border:1.5px solid var(--border); border-radius:14px; padding:14px; font-size:14px; font-weight:500; width:100%; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; font-family:'DM Sans',sans-serif; }

  /* ============================================
     AGENDA PEDIDOS — ESTILOS NUEVOS
     ============================================ */
  
  /* KPIs agenda 3 col */
  .agenda-kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .agenda-kpi { background: var(--card); border-radius: 16px; padding: 14px 12px; box-shadow: var(--shadow); border: 1px solid var(--border); text-align: center; }

  /* Dashboard */
  .dash-period-btn { padding:8px 16px;border-radius:20px;border:1.5px solid #ddd;background:white;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap;color:#555;transition:all 0.2s; }
  .dash-period-btn.active { background:#2D5A1B;border-color:#2D5A1B;color:white; }
  .vdet-tab { padding:6px 14px;border-radius:20px;border:1.5px solid #ddd;background:white;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap;color:#555;flex-shrink:0; }
  .vdet-tab.active { background:#2D5A1B;border-color:#2D5A1B;color:white; }
  .dash-kpi-card { background:white;border:1.5px solid #eee;border-radius:16px;padding:18px 16px;display:flex;flex-direction:column;gap:4px; }
  .dash-kpi-card.green { background:linear-gradient(135deg,#E8F5E9,#C8E6C9);border-color:#A5D6A7; }
  .dash-kpi-card.blue  { background:linear-gradient(135deg,#E3F2FD,#BBDEFB);border-color:#90CAF9; }
  .dash-kpi-card.orange{ background:linear-gradient(135deg,#FFF3E0,#FFE0B2);border-color:#FFCC80; }
  .dash-kpi-card.red   { background:linear-gradient(135deg,#FFEBEE,#FFCDD2);border-color:#EF9A9A; }
  .dash-kpi-num  { font-size:32px;font-weight:900;line-height:1; }
  .dash-kpi-label{ font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;opacity:0.7;margin-top:2px; }
  .dash-kpi-sub  { font-size:12px;font-weight:600;opacity:0.6; }
  .dash-bar-wrap { display:flex;align-items:center;gap:8px;margin-bottom:8px; }
  .dash-bar-label{ font-size:12px;font-weight:700;color:#333;min-width:100px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap; }
  .dash-bar-track{ flex:1;background:#f0f0f0;border-radius:6px;height:10px;overflow:hidden; }
  .dash-bar-fill { height:100%;border-radius:6px;transition:width 0.6s ease; }
  .dash-bar-val  { font-size:12px;font-weight:800;color:#333;min-width:36px;text-align:right; }
  @media (min-width:768px) {
    .dash-kpi-num { font-size:42px; }
    #dashKpis { grid-template-columns: repeat(4,1fr); }
    #dashBottomGrid { grid-template-columns: 1fr 1fr; }
  }
  .agenda-kpi-icon { font-size: 22px; margin-bottom: 6px; }
  .agenda-kpi-value { font-size: 22px; font-weight: 700; line-height: 1; }
  .agenda-kpi-label { font-size: 11px; color: var(--text-secondary); margin-top: 3px; }

  /* Tarjeta pedido agrupado */
  .pedido-card { background: var(--card); border-radius: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; cursor: pointer; transition: transform 0.15s; }
  .pedido-card:active { transform: scale(0.99); }
  .pedido-card-header { padding: 14px 16px; display: flex; align-items: center; gap: 12px; }
  .pedido-card-left { flex: 1; min-width: 0; }
  .pedido-folio { font-family: 'DM Mono', monospace; font-size: 15px; font-weight: 700; color: var(--green-dark); }
  .pedido-cliente { font-size: 13px; font-weight: 600; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pedido-meta { font-size: 11px; color: var(--text-muted); margin-top: 3px; }
