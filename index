// ==========================================
const UBICACIONES_VALIDAS = ['BN','B2','T1','T2','T3','T4','TA8','TB11','T9','T10','T12','T13','T14','Polietilenos','Fumigacion','AlmacenMaquila','AlmacenMerma','Cliente','MesaDespensas','Proveedor'];

function correrAuditor(abrirModal) {
  const hallazgos = [];

  // ── 1. MOVIMIENTOS DUPLICADOS ──────────────────────────────
  // Un folio es duplicado solo si aparece con la misma clave de producto
  const folioProductoCount = {};
  allMovimientosCompletos.forEach(m => {
    const f = (m['FolioMov'] || '').trim();
    const clave = (m['ClaveProducto'] || '').trim();
    if (!f) return;
    const key = f + '||' + clave;
    folioProductoCount[key] = (folioProductoCount[key] || 0) + 1;
  });
  const duplicados = Object.entries(folioProductoCount).filter(([,v]) => v > 1);
  duplicados.forEach(([key, count]) => {
    const [folio, clave] = key.split('||');
    hallazgos.push({ cat: 'Movimientos', nivel: 'rojo', icon: '🔁', titulo: 'Movimiento duplicado', sub: folio + (clave ? ' · ' + clave : '') + ' · aparece ' + count + ' veces' });
  });

  // ── 2. ENTRADAS SIN PROVEEDOR / SALIDAS SIN CLIENTE ────────
  allMovimientosCompletos.forEach(m => {
    const tipo = (m['TipoMov'] || '').trim();
    const estado = (m['Estado'] || '').trim();
    if (estado === 'CANCELADO') return;
    const folio = m['FolioMov'] || m['DocumentoRef'] || '—';
    if (tipo.includes('Entrada') && !m['Proveedor']) {
      hallazgos.push({ cat: 'Movimientos', nivel: 'naranja', icon: '🏭', titulo: 'Entrada sin proveedor', sub: folio + ' · ' + (m['ClaveProducto'] || '—') });
    }
    if (tipo.includes('Salida') && !m['Cliente']) {
      hallazgos.push({ cat: 'Movimientos', nivel: 'naranja', icon: '🚚', titulo: 'Salida sin cliente', sub: folio + ' · ' + (m['ClaveProducto'] || '—') });
    }
  });

  // ── 3. PEDIDOS DESPACHADOS SIN MOVIMIENTO DE SALIDA ────────
  const pedidosArr = Object.values(pedidosAgrupados || {});
  const foliosMovDesp = new Set(
    allMovimientosCompletos
      .filter(m => (m['TipoMov']||'').includes('Salida') && (m['Estado']||'') !== 'CANCELADO')
      .map(m => (m['DocumentoRef']||'').trim())
  );
  pedidosArr.forEach(p => {
    if ((p.estado || '').toLowerCase() === 'despachado') {
      const folio = (p.folio || '').trim();
      if (!foliosMovDesp.has(folio)) {
        hallazgos.push({ cat: 'Movimientos', nivel: 'rojo', icon: '📋', titulo: 'Pedido despachado sin movimiento', sub: folio + ' · ' + (p.cliente || '—') });
      }
    }
  });

  // ── 4. STOCK NEGATIVO ──────────────────────────────────────
  allProducts.forEach(p => {
    const isGranel = p.tipo === 'granel';
    const stock = isGranel ? (p.stockKg || 0) : (p.stockPz || 0);
    if (stock < 0) {
      hallazgos.push({ cat: 'Inventario', nivel: 'rojo', icon: '📉', titulo: 'Stock negativo', sub: p.clave + ' · ' + (isGranel ? stock + ' kg' : stock + ' pz') });
    }
  });

  // ── 5. RESERVADOS > DISPONIBLES ───────────────────────────
  allProducts.forEach(p => {
    const isGranel = p.tipo === 'granel';
    const stock = isGranel ? (p.stockKg || 0) : (p.stockPz || 0);
    const reservado = isGranel ? (p.reservadoKg || 0) : (p.reservado || 0);
    if (reservado > 0 && reservado > stock) {
      const faltante = reservado - stock;
      hallazgos.push({ cat: 'Inventario', nivel: 'rojo', icon: '⚠️', titulo: 'Reservado > disponible', sub: p.clave + ' · reservado ' + formatNum(reservado) + (isGranel?' kg':' pz') + ' · stock ' + formatNum(stock) + (isGranel?' kg':' pz') + ' · falta ' + formatNum(faltante) + (isGranel?' kg':' pz') });
    }
  });

  // ── 6. POR PRODUCIR (reservado > stock pero hay pedidos en producción) ──
  allProducts.forEach(p => {
    if ((p.porProducir || 0) > 0) {
      hallazgos.push({ cat: 'Inventario', nivel: 'amarillo', icon: '🏭', titulo: 'Por producir', sub: p.clave + ' · ' + formatNum(p.porProducir) + ' pz pendientes de producción' });
    }
  });

  // ── 7. UBICACIONES INVÁLIDAS O VACÍAS ──────────────────────
  allMovimientosCompletos.forEach(m => {
    const estado = (m['Estado'] || '').trim();
    if (estado === 'CANCELADO') return;
    const folio = m['FolioMov'] || '—';
    const origen = (m['UbicacionOrigen'] || '').trim();
    const destino = (m['UbicacionDestino'] || '').trim();
    if (!origen && !destino) {
      hallazgos.push({ cat: 'Ubicaciones', nivel: 'naranja', icon: '📍', titulo: 'Sin ubicación', sub: folio + ' · origen y destino vacíos' });
    } else {
      if (origen && !UBICACIONES_VALIDAS.includes(origen)) {
        hallazgos.push({ cat: 'Ubicaciones', nivel: 'amarillo', icon: '📍', titulo: 'Ubicación origen desconocida', sub: folio + ' · "' + origen + '"' });
      }
      if (destino && !UBICACIONES_VALIDAS.includes(destino)) {
        hallazgos.push({ cat: 'Ubicaciones', nivel: 'amarillo', icon: '📍', titulo: 'Ubicación destino desconocida', sub: folio + ' · "' + destino + '"' });
      }
    }
  });

  // ── 8. GRAMAJE INCONSISTENTE ───────────────────────────────
  allMovimientosCompletos.forEach(m => {
    const estado = (m['Estado'] || '').trim();
    if (estado === 'CANCELADO') return;
    const clave = (m['ClaveProducto'] || '').trim();
    const pz = parseFloat(m['CantidadPz'] || 0);
    const kg = parseFloat(m['CantidadKg'] || 0);
    if (!pz || !kg || !clave) return;
    const prod = allProducts.find(p => p.clave === clave);
    if (!prod || !prod.gramaje) return;
    const gramaje = parseFloat(prod.gramaje);
    if (!gramaje) return;
    const kgEsperado = pz * gramaje / 1000;
    const diferencia = Math.abs(kg - kgEsperado);
    const tolerancia = kgEsperado * 0.05; // 5%
    if (diferencia > tolerancia && diferencia > 10) {
      const folio = m['FolioMov'] || '—';
      hallazgos.push({ cat: 'Gramajes', nivel: 'amarillo', icon: '⚖️', titulo: 'Gramaje inconsistente', sub: folio + ' · ' + clave + ' · ' + formatNum(pz) + ' pz / ' + formatNum(kg) + ' kg · esperado ~' + formatNum(Math.round(kgEsperado)) + ' kg' });
    }
  });

  // ── ACTUALIZAR BADGE ───────────────────────────────────────
  const badge = document.getElementById('navBadgeAuditor');
  const btnBadge = document.getElementById('auditorBtnBadge');
  const rojos = hallazgos.filter(h => h.nivel === 'rojo').length;
  const total = hallazgos.length;
  if (total > 0) {
    const label = rojos > 0 ? String(rojos) : '!';
    const color = rojos > 0 ? '#E53935' : '#F57C00';
    if (badge) { badge.textContent = label; badge.style.display = ''; badge.style.background = color; }
    if (btnBadge) { btnBadge.textContent = label; btnBadge.style.display = ''; }
  } else {
    if (badge) badge.style.display = 'none';
    if (btnBadge) btnBadge.style.display = 'none';
  }

  // Guardar para abrir modal
  window._auditorHallazgos = hallazgos;
  window._auditorTs = new Date();

  if (abrirModal) abrirAuditorModal();
}

function abrirAuditorModal() {
  const hallazgos = window._auditorHallazgos || [];
  const ts = window._auditorTs;

  // Fecha
  const fechaEl = document.getElementById('auditorFecha');
  if (fechaEl && ts) fechaEl.textContent = 'Última auditoría: ' + ts.toLocaleString('es-MX');

  // Resumen chips
  const rojos   = hallazgos.filter(h => h.nivel === 'rojo').length;
  const naranjas = hallazgos.filter(h => h.nivel === 'naranja').length;
  const amarillos = hallazgos.filter(h => h.nivel === 'amarillo').length;
  const resEl = document.getElementById('auditorResumen');
  if (resEl) {
    if (hallazgos.length === 0) {
      resEl.innerHTML = '<span class="audit-chip verde">✅ Todo en orden</span>';
    } else {
      resEl.innerHTML =
        (rojos   > 0 ? '<span class="audit-chip rojo">🔴 ' + rojos + ' críticos</span>' : '') +
        (naranjas > 0 ? '<span class="audit-chip naranja">🟠 ' + naranjas + ' advertencias</span>' : '') +
        (amarillos > 0 ? '<span class="audit-chip" style="background:#FFFDE7;color:#F9A825;">🟡 ' + amarillos + ' avisos</span>' : '');
    }
  }

  // Detalle por categoría
  const detEl = document.getElementById('auditorDetalle');
  if (!detEl) { abrirModal('auditorModalOverlay'); return; }

  if (hallazgos.length === 0) {
    detEl.innerHTML = '<div class="audit-ok">✅ No se encontraron incongruencias</div>';
    abrirModal('auditorModalOverlay');
    return;
  }

  const cats = ['Movimientos', 'Inventario', 'Ubicaciones', 'Gramajes'];
  const iconCat = { Movimientos: '📈', Inventario: '📦', Ubicaciones: '📍', Gramajes: '⚖️' };
  let html = '';

  cats.forEach(cat => {
    const items = hallazgos.filter(h => h.cat === cat);
    if (!items.length) return;
    html += '<div class="audit-categoria">';
    html += '<div class="audit-cat-header">' + iconCat[cat] + ' ' + cat + ' <span style="font-size:11px;color:#888;font-weight:400;">(' + items.length + ')</span></div>';
    items.forEach(item => {
      html += '<div class="audit-item ' + item.nivel + '">';
      html += '<div class="audit-item-icon">' + item.icon + '</div>';
      html += '<div class="audit-item-text"><div class="audit-item-title">' + item.titulo + '</div><div class="audit-item-sub">' + item.sub + '</div></div>';
      html += '</div>';
    });
    html += '</div>';
  });

  detEl.innerHTML = html;
  abrirModal('auditorModalOverlay');
}
</script>
