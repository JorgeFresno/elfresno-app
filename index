function verHistorialEquipo(idx) {
  const equipo = mantEquipos[idx];
  if (!equipo) return;
  const regs = mantRegistros
    .filter(r => String(r['IDEquipo']||r['Nombre']||'').trim() === String(equipo['ID']||equipo['Nombre']||'').trim())
    .sort((a, b) => new Date(b['Fecha']) - new Date(a['Fecha']));
  
  const container = document.getElementById('mantContenido');
  const backBtn = '<button onclick="renderMantenimiento()" style="background:#F5F5F5;border:none;border-radius:10px;padding:8px 14px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;margin-bottom:12px;">← Volver</button>';
  const titulo = '<div style="font-size:16px;font-weight:900;color:#1B3A10;margin-bottom:12px;">📋 ' + equipo['Nombre'] + '</div>';
  
  if (!regs.length) {
    container.innerHTML = backBtn + titulo + '<div class="empty-state">Sin registros para este equipo</div>';
    return;
  }
  container.innerHTML = backBtn + titulo + regs.map(r => renderRegistroCard(r)).join('');
}

function abrirRegistroMantByIdx(idx) {
  const equipo = mantEquipos[idx];
