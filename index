// ── LEER MAQUILAS desde Sheets ────────────────────────────────
async function sincronizarMaquilas() {
  const btn = document.querySelector('[onclick="sincronizarMaquilas()"]');
  if (btn) { btn.disabled = true; btn.textContent = '⏳'; }
  try {
    // Leer Maquilas_Ordenes del mismo Spreadsheet principal
    const table = await fetchSheet('Maquilas_Ordenes');
    const fixed = fixFirstHeader(table, 'Acta');
    const rows  = tableToObjects(fixed);

    // Leer las 3 hojas de movimientos para KPIs
    const [tablaRec, tablaProd, tablaEnt] = await Promise.all([
      fetchSheet('Maquilas_Recepcion', true).catch(() => null),
      fetchSheet('Maquilas_Produccion', true).catch(() => null),
      fetchSheet('Maquilas_Entregas', true).catch(() => null)
    ]);

    const rowsRec  = tablaRec  ? tableToObjects(fixFirstHeader(tablaRec,  'Acta')) : [];
    const rowsProd = tablaProd ? tableToObjects(fixFirstHeader(tablaProd, 'Acta')) : [];
    const rowsEnt  = tablaEnt  ? tableToObjects(fixFirstHeader(tablaEnt,  'Acta')) : [];

    // KG recibidos por acta (solo OK)
    const kgRecPorActa = {};
    rowsRec.forEach(r => {
      const a = String(r['Acta'] || '').trim();
      if (a && String(r['Estado'] || 'OK').trim() !== 'Cancelado')
        kgRecPorActa[a] = (kgRecPorActa[a] || 0) + (parseFloat(r['KgFresno']) || 0);
    });

    // KG acondicionados por acta (solo OK) — normalizar encabezados
    const kgProdPorActa = {};
    const kgVacPorActa  = {};
    rowsProd.forEach(r => {
      const a = String(r['Acta'] || '').trim();
      if (a && String(r['Estado'] || 'OK').trim() !== 'Cancelado') {
        const kgAcond = parseFloat(r['KgAcondicionados'] || r['KGAcondicionados']) || 0;
        const kgVac   = parseFloat(r['KgVaciados']       || r['KGVaciados'])       || 0;
        kgProdPorActa[a] = (kgProdPorActa[a] || 0) + kgAcond;
        kgVacPorActa[a]  = (kgVacPorActa[a]  || 0) + kgVac;
      }
    });

    // KG entregados por acta (solo OK)
    const kgEntPorActa = {};
    rowsEnt.forEach(r => {
      const a = String(r['Acta'] || '').trim();
      if (a && String(r['Estado'] || 'OK').trim() !== 'Cancelado')
        kgEntPorActa[a] = (kgEntPorActa[a] || 0) + (parseFloat(r['PesoSalida']) || 0);
    });

    allOrdenesMAQ = rows.map(r => ({
      Folio:           String(r['Acta']              || '').trim(),
      Cliente:         r['Cliente']          || '',
      FechaLlegada:    r['FechaLlegada']     || '',
      TolvaFurgon:     r['TolvaFurgon']      || r['TolvaFurg\u00f3n'] || '',
      BultosTotal:     r['BultosTotal']      || 0,
      KgTotal:         r['KgTotal']          || 0,
      CertInternacional: r['CertInternacional'] || '',
      CertFitosanitario: r['CertFitosanitario'] || '',
      NumCertificado:  r['NumCertificado']   || '',
      PesoDocumentado: r['PesoDocumentado']  || 0,
      CambiaCostal:    r['CambiaCostal']     || 'No',
      GramosCostal:    r['GramosCostal']     || 0,
      Estado:          r['Estatus']          || r['Estado'] || 'En proceso',
      URLDrive:        r['URLDrive']         || '',
      KgRecibidos:     kgRecPorActa[String(r['Acta']||'').trim()]  || 0,
      KgProducidos:    kgProdPorActa[String(r['Acta']||'').trim()] || 0,
      KgEntregados:    kgEntPorActa[String(r['Acta']||'').trim()]  || 0,
      // Tipo se infiere o se guarda en Observaciones por ahora
      Tipo:            'Acondicionamiento',
      Producto:        'Alpiste'
    })).filter(o => o.Folio);

    renderMaquilas();
    if (document.getElementById('maqSubtitle'))
      document.getElementById('maqSubtitle').textContent = allOrdenesMAQ.length + ' actas · ' + new Date().toLocaleDateString('es-MX');

    renderMaqInicioTolva();

  } catch(e) {
    console.error('sincronizarMaquilas:', e);
    showToast('Error al cargar maquilas', 'error');
  }
  if (btn) { btn.disabled = false; btn.textContent = '↻ Actualizar'; }
}

function renderMaqInicioTolva() {
  const titulo    = document.getElementById('maqInicioTitle');
  const container = document.getElementById('maqInicioContainer');
  if (!titulo || !container) return;

  // Calcular KG en tolva por acta
  const enTolva = allOrdenesMAQ
    .filter(o => o.Estado !== 'Entrega completa' && o.Estado !== 'Cerrada' && o.Estado !== 'Cancelada')
    .map(o => {
      const kgRec   = parseFloat(o.KgRecibidos  || 0);
      const kgProd  = parseFloat(o.KgProducidos || 0);
      const kgEnt   = parseFloat(o.KgEntregados || 0);
      // KG en tolva = vaciados - acondicionados
      // Aproximamos con lo disponible en allOrdenesMAQ
      // El valor exacto lo tiene el detalle — aquí mostramos actas activas con KG recibidos
      return { folio: o.Folio, cliente: o.Cliente, kgRec, kgProd, kgEnt,
               kgDisp: Math.max(0, kgProd - kgEnt) };
    })
    .filter(o => o.kgRec > 0);

  if (!enTolva.length) {
    titulo.style.display = 'none';
    container.innerHTML = '';
    return;
  }

  titulo.style.display = '';
  container.innerHTML = enTolva.map(o => `
    <div class="action-card" onclick="navTo('maquilas');setTimeout(()=>abrirDetalleMaquila('${o.folio}'),300)">
      <div class="action-icon" style="background:#E8F5E9;font-size:20px;">🌿</div>
      <div class="action-body">
        <div class="action-title" style="font-size:13px;">${o.folio} · ${o.cliente}</div>
        <div class="action-sub">
          📦 ${formatNum(o.kgRec)} kg rec.
          ${o.kgProd > 0 ? ' · 🌿 ' + formatNum(o.kgProd) + ' kg acond.' : ''}
          ${o.kgDisp > 0 ? ' · ✅ ' + formatNum(o.kgDisp) + ' kg disp.' : ''}
        </div>
      </div>
      <div class="action-arrow">›</div>
    </div>`).join('');
}

