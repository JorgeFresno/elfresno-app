        '<div style="font-size:14px;font-weight:800;color:#1B3A10;">' + e['Nombre'] + '</div>' +
        '<div style="font-size:11px;color:#888;margin-top:2px;">' + (e['Tipo']||'') + ' · <span style="background:#E8F5E9;color:#2D5A1B;padding:2px 8px;border-radius:20px;font-weight:700;">Preventivo</span></div>' +
        '</div></div>' +
        '<div style="background:' + s.bg + ';color:' + s.color + ';border-radius:20px;padding:4px 10px;font-size:11px;font-weight:800;white-space:nowrap;">' + s.emoji + ' ' + s.label + '</div>' +
        '</div>' +
        // Stats
        '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;">' +
        '<div style="text-align:center;"><div style="font-size:16px;font-weight:900;color:' + barColor + ';">' + diasText + '</div><div style="font-size:10px;color:#888;">Sin mant.</div></div>' +
