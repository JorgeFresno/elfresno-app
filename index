function procesarImagenQR(input) {
  const file = input.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = (e) => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width  = img.width;
      canvas.height = img.height;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);
      const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);

      if (typeof jsQR === 'undefined') {
        showToast('❌ Librería QR no disponible', 'error');
        return;
      }

      const code = jsQR(imageData.data, imageData.width, imageData.height, {
        inversionAttempts: 'dontInvert'
      });

      if (code) {
        procesarQR(code.data);
      } else {
        showToast('❌ No se detectó QR — intenta de nuevo', 'error');
      }

      // Reset input para poder escanear de nuevo
      input.value = '';
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function procesarQR(texto) {
  const BASE = 'https://jorgefresno.github.io/fresno2026_app/';
  const resultDiv  = document.getElementById('scanResult');
  const resultText = document.getElementById('scanResultText');
  const resultBtn  = document.getElementById('scanResultBtn');

  if (!resultDiv) return;

  if (texto.startsWith(BASE)) {
    try {
      const url    = new URL(texto);
      const pedido = url.searchParams.get('pedido');
      const mov    = url.searchParams.get('mov');

      if (pedido) {
        const folio = decodeURIComponent(pedido);
        resultText.textContent = '📋 Pedido encontrado: ' + folio;
        resultBtn.textContent  = '🚀 Abrir pedido';
        resultBtn.onclick = () => {
          resultDiv.style.display = 'none';
          navTo('agenda');
          setTimeout(() => {
            if (pedidosAgrupados[folio]) openPedidoDetalle(folio);
            else showToast('Pedido: ' + folio, 'success');
          }, 600);
        };
      } else if (mov) {
        const folio = decodeURIComponent(mov);
        resultText.textContent = '📦 Movimiento encontrado: ' + folio;
        resultBtn.textContent  = '🔍 Abrir movimiento';
        resultBtn.onclick = () => {
          resultDiv.style.display = 'none';
          navTo('movimientos');
          setTimeout(() => {
            const inp = document.getElementById('movSearchInput');
            if (inp) { inp.value = folio; renderMovimientos(); }
            const idx = allMovimientos.findIndex(m => (m['FolioMov']||'') === folio);
            if (idx >= 0) setTimeout(() => openDetalle(idx), 400);
          }, 600);
        };
      }
    } catch(e) {
      resultText.textContent = '🔍 ' + texto.substring(0, 50);
      resultBtn.textContent  = 'Cerrar';
      resultBtn.onclick = () => { resultDiv.style.display = 'none'; };
    }
  } else {
    resultText.textContent = '🔍 ' + texto.substring(0, 60) + (texto.length > 60 ? '...' : '');
    resultBtn.textContent  = 'Cerrar';
    resultBtn.onclick = () => { resultDiv.style.display = 'none'; };
  }

  resultDiv.style.display = 'block';
  showToast('✅ QR detectado', 'success');
}

