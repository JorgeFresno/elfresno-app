function openModal() {
  resetForm();
  generarFolio();
  document.getElementById('fFecha').value = new Date().toISOString().split('T')[0];
  abrirModal('modalOverlay');
}
function closeModal() { cerrarModal('modalOverlay'); }
function closeModalOutside(e) { if (e.target === document.getElementById('modalOverlay')) closeModal(); }

function resetForm() {
  selectedTipo = ''; selectedProducto = null;
  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
  ['fTipoMov','fProductoSearch','fClaveProducto','fDescripcion','fCantPz','fCantKg','fDocRef','fProveedorSearch','fProveedor','fClienteSearch','fCliente','fLote','fObs'].forEach(id => {
    const el = document.getElementById(id); if (el) { el.value = ''; el.classList.remove('error'); }
  });
  document.getElementById('fOrigen').value = '';
  document.getElementById('fDestino').value = '';
  document.getElementById('fEstado').value = 'OK';
  document.getElementById('fProductoSuggestions').style.display = 'none';
  document.getElementById('fProductoSelected').style.display = 'none';
  document.getElementById('fProveedorSug').style.display = 'none';
  document.getElementById('fClienteSug').style.display = 'none';
}

function selectTipo(tipo, el) {
  // Mostrar toggle recepción solo en Entrada compra
  const bar = document.getElementById('recepcionToggleBar');
  if (bar) bar.style.display = tipo === 'Entrada compra' ? 'block' : 'none';
  if (tipo !== 'Entrada compra') {
    document.getElementById('recepcionModoToggle').checked = false;
    toggleRecepcionMode();
  }
  selectedTipo = tipo;
  document.getElementById('fTipoMov').value = tipo;
  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  if (tipo.includes('Entrada compra')) { document.getElementById('fOrigen').value='Proveedor'; document.getElementById('fDestino').value='BN'; }
  else if (tipo.includes('Salida venta')) { document.getElementById('fOrigen').value='BN'; document.getElementById('fDestino').value='Cliente'; }
  else if (tipo.includes('Salida a producción')) { document.getElementById('fOrigen').value='BN'; document.getElementById('fDestino').value='T1'; }
  else if (tipo.includes('Entrada producción')) { document.getElementById('fOrigen').value='T1'; document.getElementById('fDestino').value='BN'; }
}

function searchProductos() {
  const q = document.getElementById('fProductoSearch').value.toLowerCase().trim();
  const sugBox = document.getElementById('fProductoSuggestions');
  if (q.length < 2) { sugBox.style.display = 'none'; return; }
  const matches = allProducts.filter(p => p.clave.toLowerCase().includes(q) || p.nombre.toLowerCase().includes(q)).slice(0, 6);
  if (!matches.length) { sugBox.style.display = 'none'; return; }
  sugBox.innerHTML = matches.map(p => `
    <div class="suggestion-item" onclick="selectProducto('${p.clave}','${p.nombre.replace(/'/g,"\\'")}')">
      <div class="suggestion-name">${p.nombre}</div>
      <div class="suggestion-code">${p.clave} · ${p.tipo === 'granel' ? 'Granel' : 'PT'}</div>
    </div>`).join('');
  sugBox.className = 'product-suggestion';
  sugBox.style.display = 'block';
}

function selectProducto(clave, nombre) {
  selectedProducto = { clave, nombre };
  document.getElementById('fClaveProducto').value = clave;
  document.getElementById('fDescripcion').value = nombre;
  document.getElementById('fProductoLabel').textContent = `${clave} · ${nombre}`;
  document.getElementById('fProductoSearch').value = '';
  document.getElementById('fProductoSuggestions').style.display = 'none';
  document.getElementById('fProductoSelected').style.display = 'block';
}

function clearProducto() {
  selectedProducto = null;
  document.getElementById('fClaveProducto').value = '';
  document.getElementById('fDescripcion').value = '';
  document.getElementById('fProductoSelected').style.display = 'none';
}

async function generarFolio() {
  const last = allMovimientos.map(m => parseInt(String(m['FolioMov']||'').replace(/\D/g,''))||0);
  const maxNum = last.length ? Math.max(...last) : 0;
  const siguiente = String(maxNum + 1).padStart(5, '0');
  document.getElementById('folioPreview').textContent = `Mov_${siguiente}`;
  return `Mov_${siguiente}`;
}

async function submitMovimiento() {
  const recepcionActivo = document.getElementById('recepcionModoToggle')?.checked;
  if (recepcionActivo) { await submitRecepcion(); return; }
  if (!selectedTipo) { showToast('⚠️ Selecciona el tipo de movimiento', 'error'); return; }
  if (!document.getElementById('fClaveProducto').value) { showToast('⚠️ Selecciona un producto', 'error'); return; }
  const cantPz = document.getElementById('fCantPz').value;
  const cantKg = document.getElementById('fCantKg').value;
  const origen = document.getElementById('fOrigen').value;
  const destino = document.getElementById('fDestino').value;
  const docRef = document.getElementById('fDocRef').value.trim();
  let hasError = false;
  if (!cantPz && !cantKg) { ['fCantPz','fCantKg'].forEach(id => document.getElementById(id).classList.add('error')); hasError=true; }
  if (!origen) { document.getElementById('fOrigen').classList.add('error'); hasError=true; }
  if (!destino) { document.getElementById('fDestino').classList.add('error'); hasError=true; }
  if (!docRef) { document.getElementById('fDocRef').classList.add('error'); hasError=true; }
  if (hasError) { showToast('⚠️ Completa los campos obligatorios', 'error'); return; }
  const folio = document.getElementById('folioPreview').textContent;
  const payload = {
    movId: generateMovId(), FechaMov: document.getElementById('fFecha').value,
    TipoMov: selectedTipo, FolioMov: folio, DocumentoRef: docRef,
    ClaveProducto: document.getElementById('fClaveProducto').value,
    Descripcion: document.getElementById('fDescripcion').value,
    UbicacionOrigen: origen, UbicacionDestino: destino,
    CantidadPz: parseFloat(cantPz)||0, CantidadKg: parseFloat(cantKg)||0,
    Proveedor: document.getElementById('fProveedor').value,
    Cliente: document.getElementById('fCliente').value,
    LoteCaducidad: document.getElementById('fLote').value,
    Captura: 'U01', Estado: document.getElementById('fEstado').value,
    Observaciones: document.getElementById('fObs').value, Folio_QR: folio
  };
  const btn = document.getElementById('fSubmitBtn');
  btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>Guardando...';
  try {
    await Promise.all([
      fetch(APPS_SCRIPT_URL, { method:'POST', mode:'no-cors', headers:{'Content-Type':'text/plain'}, body: JSON.stringify(payload) }),
      new Promise(r => setTimeout(r, 1500))
    ]);
    showToast('✅ Movimiento guardado: ' + folio, 'success');
    closeModal();
    setTimeout(() => syncData(), 1500);
  } catch(e) {
    showToast('❌ Error al guardar. Revisa conexión.', 'error');
  } finally { btn.disabled=false; btn.innerHTML='💾 Guardar movimiento'; }
}

async function submitRecepcion() {
  if (!camiones.length) { showToast('❌ Agrega al menos un camión', 'error'); return; }
  const sinKg = camiones.filter(c => c.kgNeto <= 0);
  if (sinKg.length) { showToast('❌ Todos los camiones deben tener KG neto > 0', 'error'); return; }

  const clave       = document.getElementById('fClaveProducto').value.trim();
  const descripcion = document.getElementById('fDescripcion').value.trim();
  const fecha       = document.getElementById('fFecha').value;
  const origen      = document.getElementById('fOrigen').value;
  const destino     = document.getElementById('fDestino').value;
  const proveedor   = document.getElementById('fProveedor').value.trim();
  const lote        = document.getElementById('fLote').value.trim();
  const obsBase     = document.getElementById('fObs').value.trim();
  const docRef      = document.getElementById('fDocRef').value.trim();
  const captura     = currentUser?.nombre || 'U01';

  if (!clave)   { showToast('❌ Selecciona un producto', 'error'); return; }
  if (!fecha)   { showToast('❌ Captura la fecha', 'error'); return; }
  if (!destino) { showToast('❌ Selecciona destino', 'error'); return; }
  if (!docRef)  { showToast('❌ Captura el folio padre en Documento referencia', 'error'); return; }

  const btn = document.getElementById('fSubmitBtn');
  btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>Guardando camión 1 de ' + camiones.length + '...';
  let guardados = 0;

  for (let i = 0; i < camiones.length; i++) {
    const c = camiones[i];
    const folioMov = docRef + '-C' + String(i+1).padStart(2,'0');
    const obsCompleta = [
      c.chofer  ? 'Chofer: ' + c.chofer   : '',
      c.placa   ? 'Placa: '  + c.placa    : '',
      c.folio   ? 'Ticket: ' + c.folio    : '',
      c.kgBruto ? 'Bruto: '  + c.kgBruto + ' kg' : '',
      c.kgTara  ? 'Tara: '   + c.kgTara  + ' kg' : '',
      c.sacos   ? 'Sacos: '  + c.sacos           : '',
      obsBase
    ].filter(Boolean).join(' | ');

    const mid = 'mid_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
    const payload = {
      FechaMov: fecha, TipoMov: 'Entrada compra', FolioMov: folioMov,
      DocumentoRef: docRef, ClaveProducto: clave, Descripcion: descripcion,
      Proveedor: proveedor, Cliente: '',
      UbicacionOrigen: origen || 'Proveedor', UbicacionDestino: destino,
      CantidadPz: c.sacos || 0, CantidadKg: c.kgNeto,
      LoteCaducidad: lote, Captura: captura, Estado: 'OK',
      Observaciones: obsCompleta, Folio_QR: folioMov, movId: mid
    };

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST', mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(payload)
      });
      guardados++;
      if (i < camiones.length - 1) {
        btn.innerHTML = '<span class="btn-spinner"></span>Guardando camión ' + (i+2) + ' de ' + camiones.length + '...';
        await new Promise(r => setTimeout(r, 400));
      }
    } catch(e) { console.error('Error camión ' + (i+1), e); }
  }

  const totalNeto = camiones.reduce((s, c) => s + c.kgNeto, 0);
  showToast('✅ Recepción guardada: ' + guardados + ' camiones · ' + totalNeto.toLocaleString('es-MX') + ' kg netos', 'success');
  btn.disabled = false; btn.innerHTML = '🚛 Guardar recepción completa';
  closeModal();
  camiones = [];
  document.getElementById('recepcionModoToggle').checked = false;
  toggleRecepcionMode();
  setTimeout(() => syncData(), 2000);
}

async function cancelarMovimiento(folio) {
  console.log('cancelarMovimiento llamado con folio:', folio);
  if (!folio || folio === 'undefined') { showToast('❌ Folio no identificado', 'error'); return; }

  // Verificar estado actual en datos locales
  const movLocal = allMovimientos.find(m => (m['FolioMov']||'') === folio);
  if (movLocal && String(movLocal['Estado']||'').trim() === 'Cancelado') {
    showToast('⚠️ Este movimiento ya está cancelado', 'error');
    return;
  }

  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center;';
  overlay.innerHTML = `
    <div style="background:white;border-radius:16px;padding:24px;margin:20px;max-width:360px;width:100%;">
      <div style="font-weight:700;font-size:16px;margin-bottom:8px;">⚠️ Cancelar movimiento</div>
      <div style="font-size:14px;color:#555;margin-bottom:12px;">¿Confirmas cancelar <strong>${folio}</strong>? Esta acción no se puede deshacer.</div>
      <textarea id="cancelMovMotivo" placeholder="Motivo de cancelación..." style="width:100%;min-height:70px;border:1.5px solid #ddd;border-radius:10px;padding:10px 12px;font-size:14px;font-family:inherit;resize:vertical;box-sizing:border-box;outline:none;margin-bottom:4px;" onfocus="this.style.borderColor='#E53935'" onblur="this.style.borderColor='#ddd'"></textarea>
      <div id="cancelMovError" style="color:#E53935;font-size:12px;margin-bottom:12px;display:none;">El motivo es obligatorio</div>
      <div style="display:flex;gap:10px;">
        <button id="cancelNo" style="flex:1;padding:12px;border-radius:10px;border:1.5px solid #ddd;background:white;font-size:14px;cursor:pointer;font-family:inherit;">No, regresar</button>
        <button id="cancelSi" style="flex:1;padding:12px;border-radius:10px;border:none;background:#E53935;color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;">Sí, cancelar</button>
      </div>
    </div>`;
  document.body.appendChild(overlay);
  
  await new Promise(resolve => {
    document.getElementById('cancelNo').onclick = () => { overlay.remove(); resolve(false); };
    document.getElementById('cancelSi').onclick = () => {
      const motivo = document.getElementById('cancelMovMotivo').value.trim();
      if (!motivo) {
        document.getElementById('cancelMovError').style.display = 'block';
        return;
      }
      const btnSi = document.getElementById('cancelSi');
      btnSi.disabled = true;
      btnSi.innerHTML = '<span class="btn-spinner"></span>Cancelando...';
      overlay.remove();
      resolve(motivo);
    };
  }).then(async motivo => {
    if (!motivo) return;
    try {
      showToast('Cancelando ' + folio + '...', '');
      await Promise.all([
        fetch(APPS_SCRIPT_URL, { 
          method:'POST', mode:'no-cors', 
          headers:{'Content-Type':'text/plain'}, 
          body: JSON.stringify({ accion:'cancelar', FolioMov: folio, Motivo: motivo, Captura: currentUser?.nombre || 'Sistema' }) 
        }),
        new Promise(r => setTimeout(r, 1500))
      ]);
      // Actualizar estado local inmediatamente
      if (movLocal) movLocal['Estado'] = 'Cancelado';
      // Re-renderizar el modal con estado actualizado en lugar de cerrarlo
      const idx = allMovimientos.findIndex(m => (m['FolioMov']||'') === folio);
      if (idx >= 0) openDetalle(idx);
      showToast('✅ ' + folio + ' cancelado', 'success');
      setTimeout(() => syncData(), 2000);
    } catch(e) { 
      console.error('Error cancelar:', e);
      showToast('❌ Error al cancelar.', 'error'); 
    }
  });
}

