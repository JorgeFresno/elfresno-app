        <div style="font-size:11px;color:#aaa;margin-top:2px;">${l.clave} · ${l.cantPz > 0 ? l.cantPz+' pz' : ''} ${l.cantKg > 0 ? l.cantKg+' kg' : ''}</div>
        <div style="font-size:11px;color:#E53935;margin-top:4px;">No se generará movimiento</div>
      </div>`
    ).join('');
  }

  container.innerHTML = html;
  document.getElementById('despachoConfirmBtn').onclick = () => confirmarDespacho(folio, conStock, sinStock);
  abrirModal(overlay.id);
}

async function confirmarDespacho(folio, conStock, sinStock) {
  // Validar lotes y cantidades
  const lotes = conStock.map((l, i) => {
    const lote    = document.getElementById('lote_cs_' + i)?.value.trim() || '';
    const cantInput = parseFloat(document.getElementById('cant_cs_' + i)?.value) || 0;
    const cantTotal = l.cantPz > 0 ? l.cantPz : l.cantKg;
    const cantDespachar = cantInput > 0 ? cantInput : cantTotal;
    const esParcial = cantDespachar < cantTotal;
    return { clave: l.clave, descripcion: l.descripcion, lote, cantDespachar, cantTotal, esParcial };
  });

  const sinLote = lotes.filter(l => !l.lote);
  if (sinLote.length) {
    showToast('❌ Captura el lote de todos los productos a despachar', 'error');
    conStock.forEach((l, i) => {
      const inp = document.getElementById('lote_cs_' + i);
      if (inp && !inp.value.trim()) inp.style.borderColor = 'red';
    });
    return;
  }
  if (!conStock.length) {
    showToast('⛔ No hay productos con stock para despachar', 'error');
    return;
  }

  // Determinar si es despacho parcial o completo
  const esParcialTotal = lotes.some(l => l.esParcial) || sinStock.length > 0;
  const estadoNuevo    = esParcialTotal ? 'Entrega parcial' : 'Despachado';

  document.getElementById('despachoModalOverlay').classList.remove('open');
  const btnDespacho = document.getElementById('despachoConfirmBtn');
  if (btnDespacho) { btnDespacho.disabled = true; btnDespacho.innerHTML = '<span class="btn-spinner"></span>Despachando...'; }
  showToast('Despachando pedido...', '');

  try {
    await Promise.all([
      fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({
          accion: 'despacharPedido',
          PedidoRQF: folio,
          lotesPorProducto: lotes,
          clavesOmitidas: (sinStock||[]).map(l => l.clave),
          esParcial: esParcialTotal,
          estadoNuevo: estadoNuevo
        })
      }),
      new Promise(r => setTimeout(r, 1500))
    ]);

    if (pedidosAgrupados[folio]) pedidosAgrupados[folio].estado = estadoNuevo;
    allPedidosRaw.forEach(r => {
      const f = r['Pedido/RQF'] || r['PedidoRQF'] || '';
      if (String(f).trim() === folio) r['EstadoPedido'] = estadoNuevo;
    });

    document.getElementById('pedDetModalOverlay').classList.remove('open');
    renderAgenda();
    updateAgendaKPIs();
    showToast((esParcialTotal ? '📦 Entrega parcial · ' : '🚀 Pedido despachado · ') + folio, 'success');
    setTimeout(() => loadAgenda(), 3000);
    setTimeout(() => generarTicket(folio), 400);

  } catch(e) {
    showToast('❌ Error al despachar', 'error');
  }
}

