function getPeriodoFiltro() {
  const val = document.getElementById('repPeriodo').value;
  const hoy = new Date();
  const inicio = new Date();
  if (val === 'mes')       inicio.setDate(1);
  if (val === 'trimestre') inicio.setMonth(hoy.getMonth() - 3);
  if (val === 'anio')      inicio.setMonth(0); inicio.setDate(1);
  if (val === 'todo')      return null;
  inicio.setHours(0,0,0,0);
  return inicio;
}

function parseFechaPedido(str) {
  if (!str) return null;
  const s = String(str).trim();
  const p = s.split(/[-\/]/);
  if (p.length === 3) {
    const a = parseInt(p[0]), b = parseInt(p[1]), c = parseInt(p[2]);
    if (p[0].length === 4) {
      // YYYY/MM/DD
      return new Date(a, b-1, c);
    } else if (c > 31) {
      // c es el año
      if (a <= 12 && b > 12) return new Date(c, a-1, b); // MM/DD/YYYY (Sheets)
      if (a > 12) return new Date(c, b-1, a);             // DD/MM/YYYY
      return new Date(c, a-1, b);                         // asumir MM/DD/YYYY
    }
  }
  const d = new Date(s);
  if (!isNaN(d)) return d;
  return null;
}

function pedidosDentrodePeriodo(inicio) {
  return Object.values(pedidosAgrupados).filter(p => {
    if (!inicio) return true;
    const f = parseFechaPedido(p.fechaPedido);
    return f && f >= inicio;
  });
}

