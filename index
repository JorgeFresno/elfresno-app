async function guardarProduccion() {
  const fecha       = document.getElementById('prodFecha').value;
  const personal    = document.getElementById('prodPersonal').value.trim();
  const obs         = document.getElementById('prodObs').value.trim();
  const granelClave = document.getElementById('prodGranelOrigen').value;
  const ubicOrigen  = document.getElementById('prodUbicOrigen').value;
  const ptClave     = document.getElementById('prodPTOrigen').value;
  const lote        = document.getElementById('prodLote').value.trim();
  const ubicDest    = document.getElementById('prodUbicDestino').value;
  const folioMaq    = document.getElementById('prodFolioMaquila').value.trim();
