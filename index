async function fetchSheetSimple(sheetName) {
  // For sheets with headers in row 1 (no logo/title rows)
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(sheetName)}`;
  const r = await fetch(url);
  const txt = await r.text();
  const json = JSON.parse(txt.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\)/)[1]);
  const rows = json.table.rows || [];
  const cols = json.table.cols.map(c => c.label || '');
  return rows.map(row => {
    const obj = {};
    cols.forEach((col, i) => { obj[col] = row.c?.[i]?.v ?? ''; });
    return obj;
  });
}

// Extrae lista plana de hojas con una sola columna
async function fetchSimpleList(sheetName, skipWords) {
  const table = await fetchSheet(sheetName);
  if (!table || !table.rows) return [];
  const skip = skipWords || [];
  return table.rows
    .map(row => row && row.c && row.c[0] ? String(row.c[0].v || '').trim() : '')
    .filter(v => v && !skip.includes(v.toUpperCase()));
}

