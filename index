function getEstadoChip(estado) {
  const map = {
    'Pendiente':    ['pe-pendiente',   '⏳ Pendiente'],
    'EnProduccion': ['pe-enproduccion','🏭 En prod.'],
    'Completo':     ['pe-completo',    '✅ Completo'],
    'Despachado':   ['pe-despachado',  '🚀 Despachado'],
    'Cancelado':    ['pe-cancelado',   '❌ Cancelado'],
  };
  const [cls, label] = map[estado] || ['pe-pendiente', estado];
  return `<div class="pedido-estado-chip ${cls}">${label}</div>`;
}

function getSemaforoClass(linea) {
  // Si tiene datos de disponibilidad, calcular
  if (linea.cantPz > 0) {
    if (linea.faltantePz === 0 && linea.pzDisp >= linea.cantPz) return 'sem-verde';
    if (linea.pzDisp > 0) return 'sem-amarillo';
    return 'sem-rojo';
  }
  if (linea.cantKg > 0) {
    if (linea.faltanteKg === 0 && linea.kgDisp >= linea.cantKg) return 'sem-verde';
    if (linea.kgDisp > 0) return 'sem-amarillo';
    return 'sem-rojo';
  }
  return 'sem-amarillo';
}

function renderAgenda() {
  const search = (document.getElementById('agendaSearchInput')?.value || '').toLowerCase().trim();
  let lista = Object.values(pedidosAgrupados);

  // Filtro por estado
  if (currentAgendaFilter !== 'todos') {
    lista = lista.filter(p => p.estado === currentAgendaFilter);
  }

  // Búsqueda
  if (search) {
    lista = lista.filter(p =>
      p.folio.toLowerCase().includes(search) ||
      p.cliente.toLowerCase().includes(search) ||
      p.lineas.some(l => l.clave.toLowerCase().includes(search) || l.descripcion.toLowerCase().includes(search))
    );
  }

  // Ordenar: urgentes primero, luego por días restantes
  lista.sort((a, b) => {
    const prioOrder = { 'Alta': 0, 'Media': 1, '': 2, 'Baja': 3 };
    if (prioOrder[a.prioridad] !== prioOrder[b.prioridad]) return prioOrder[a.prioridad] - prioOrder[b.prioridad];
    return (a.diasRestantes || 0) - (b.diasRestantes || 0);
  });

  const container = document.getElementById('agendaContainer');
  if (!lista.length) {
    container.innerHTML = '<div class="empty-state">📋 No hay pedidos que coincidan</div>';
    return;
  }

  container.innerHTML = lista.map(ped => {
    const lineasHTML = ped.lineas.slice(0, 4).map(l => {
      // Empacado: solo pz — Granel: pz + kg
      const esGranelLinea = l.cantKg > 0;
      const qty = esGranelLinea
        ? `${formatNum(l.cantPz > 0 ? l.cantPz : '')} ${l.cantPz > 0 ? 'pz · ' : ''}${formatNum(l.cantKg)} kg`
        : `${formatNum(l.cantPz)} pz`;
      const semClass = getSemaforoClass(l);
      return `<div class="pedido-linea">
        <div class="pedido-linea-semaforo ${semClass}"></div>
        <div class="pedido-linea-clave">${l.clave}</div>
        <div class="pedido-linea-desc">${l.descripcion}</div>
        <div class="pedido-linea-qty">${qty}</div>
      </div>`;
    }).join('');

    const masLineas = ped.lineas.length > 4
      ? `<div class="pedido-linea" style="justify-content:center;color:var(--text-muted);font-size:11px;padding:8px 16px;">+${ped.lineas.length - 4} productos más</div>`
      : '';

    const diasStr = ped.diasRestantes < 0
      ? `<span style="color:var(--red);font-weight:600;">${Math.abs(ped.diasRestantes)} días vencido</span>`
      : ped.diasRestantes === 0
      ? `<span style="color:var(--orange);font-weight:600;">Vence hoy</span>`
      : `${ped.diasRestantes} días restantes`;

    const fechaComp = formatDate(ped.fechaCompromiso);

    const folioEsc = encodeURIComponent(ped.folio);
    return `<div class="pedido-card" onclick="openPedidoDetalle(decodeURIComponent('${folioEsc}'))">
      <div class="pedido-card-header">
        <div class="pedido-card-left">
          <div class="pedido-folio">${ped.folio}</div>
          <div class="pedido-cliente">${ped.cliente}</div>
          <div class="pedido-meta">📅 ${fechaComp !== '—' ? 'Entrega: '+fechaComp : ''} · ${diasStr}${ped.vendedor ? ' · '+ped.vendedor : ''}</div>
        </div>
        <div class="pedido-right">
          ${getEstadoChip(ped.estado)}
          <div class="pedido-productos-count">${ped.lineas.length} producto${ped.lineas.length !== 1 ? 's' : ''}</div>
        </div>
      </div>
      <div class="pedido-lineas">
        ${lineasHTML}
        ${masLineas}
      </div>
    </div>`;
  }).join('');
}

