// Drag arrastrable para el botón flotante
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    const fab = document.getElementById('alfredoFab');
    if (!fab) return;
    let dragging = false, startX, startY, origX, origY;

    function onStart(e) {
      const touch = e.touches ? e.touches[0] : e;
      startX = touch.clientX; startY = touch.clientY;
      const rect = fab.getBoundingClientRect();
      origX = rect.left; origY = rect.top;
      dragging = false;
      fab.addEventListener(e.touches ? 'touchmove' : 'mousemove', onMove, { passive: false });
      fab.addEventListener(e.touches ? 'touchend' : 'mouseup', onEnd);
    }

    function onMove(e) {
      const touch = e.touches ? e.touches[0] : e;
      const dx = touch.clientX - startX;
      const dy = touch.clientY - startY;
      if (Math.abs(dx) > 5 || Math.abs(dy) > 5) dragging = true;
      if (!dragging) return;
      e.preventDefault();
      const newX = origX + dx;
      const newY = origY + dy;
      const maxX = window.innerWidth - fab.offsetWidth;
      const maxY = window.innerHeight - fab.offsetHeight;
      fab.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
      fab.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
      fab.style.right = 'auto';
      fab.style.bottom = 'auto';
      // Mover también el modal
      const modal = document.getElementById('alfredoModal');
      if (modal && alfredoAbierto) posicionarModal();
    }

    function onEnd(e) {
      fab.removeEventListener('touchmove', onMove);
      fab.removeEventListener('mousemove', onMove);
      fab.removeEventListener('touchend', onEnd);
      fab.removeEventListener('mouseup', onEnd);
      if (dragging) { e.preventDefault(); posicionarModal(); }
    }

    fab.addEventListener('touchstart', onStart, { passive: true });
    fab.addEventListener('mousedown', onStart);
  });
})();

function posicionarModal() {
  const fab = document.getElementById('alfredoFab');
  const modal = document.getElementById('alfredoModal');
  if (!fab || !modal) return;
  const rect = fab.getBoundingClientRect();
  const modalW = modal.offsetWidth || 360;
  const modalH = modal.offsetHeight || 520;
  let left = rect.left + rect.width / 2 - modalW / 2;
  let top = rect.top - modalH - 12;
  if (top < 10) top = rect.bottom + 12;
  if (left < 8) left = 8;
  if (left + modalW > window.innerWidth - 8) left = window.innerWidth - modalW - 8;
  modal.style.left = left + 'px';
  modal.style.top = top + 'px';
  modal.style.right = 'auto';
  modal.style.bottom = 'auto';
}

