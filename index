async function cambiarEstadoPedido(folio, nuevoEstado) {
  const mensajes = {
    'EnProduccion': '¿Pasar el pedido ' + folio + ' a En Producción?',
    'Completo': '¿Marcar el pedido ' + folio + ' como Completo?',
    'Cancelado': '¿Cancelar el pedido ' + folio + '? Esta acción no se puede deshacer.',
    'Despachado': '¿Marcar el pedido ' + folio + ' como Despachado?'
  };
  if (!confirm(mensajes[nuevoEstado] || '¿Confirmar cambio de estado?')) return;

  showToast('⏳ Actualizando estado...', '');
  try {
    await fetch(APPS_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        accion: 'cambiarEstadoPedido',
        PedidoRQF: folio,
        NuevoEstado: nuevoEstado
      })
    });

    // Actualizar localmente
    if (pedidosAgrupados[folio]) {
      pedidosAgrupados[folio].estado = nuevoEstado;
    }
    allPedidosRaw.forEach(r => {
      const f = r['Pedido/RQF'] || r['PedidoRQF'] || '';
      if (String(f).trim() === folio) r['EstadoPedido'] = nuevoEstado;
    });

    document.getElementById('pedDetModalOverlay').classList.remove('open');
    renderAgenda();
    updateAgendaKPIs();
    showToast('✅ Estado actualizado: ' + nuevoEstado, 'success');
    setTimeout(() => loadAgenda(), 2000);
  } catch(e) {
    showToast('❌ Error al actualizar estado', 'error');
  }
}

async function despacharPedido(folio) {
  const ped = pedidosAgrupados[folio];
  if (!ped) return;

  // Construir modal de despacho con lote por producto + validación stock
  const lineas = ped.lineas || [];
  
  // Abrir modal — el modal ya separa con stock vs sin stock
  abrirModalDespacho(folio, lineas);
}

function getStockTotal(clave) {
  const ubicProd = allUbicaciones.find(u => u.clave === clave);
  if (!ubicProd) return 0;
  return Object.entries(ubicProd.ubicaciones)
    .filter(([k]) => !['Total_ubicaciones','Es_Pieza',''].includes(k))
    .reduce((sum, [, v]) => sum + (parseFloat(v)||0), 0);
}

function abrirModalDespacho(folio, lineas) {
  const overlay = document.getElementById('despachoModalOverlay');
  document.getElementById('despachoModalFolio').textContent = '🚀 Despachar ' + folio;

  // Separar con stock vs sin stock
  const conStock  = lineas.filter(l => getStockTotal(l.clave) > 0);
  const sinStock  = lineas.filter(l => getStockTotal(l.clave) <= 0);

  const container = document.getElementById('despachoLineasContainer');
  let html = '';

  // Productos que SÍ se despachan
  if (conStock.length) {
    html += `<div style="font-size:11px;font-weight:700;color:#2D5A1B;letter-spacing:.06em;margin-bottom:8px;padding:0 2px;">✅ SE DESPACHARÁN (${conStock.length})</div>`;
    html += conStock.map((l, i) => {
      const stock = getStockTotal(l.clave);
      const ubicProd = allUbicaciones.find(u => u.clave === l.clave);
      return `
        <div style="background:#F1F8F1;border-radius:12px;padding:14px;margin-bottom:10px;border:1.5px solid #C8E6C9;">
          <div style="font-weight:700;font-size:13px;margin-bottom:2px;">${l.descripcion || l.clave}</div>
          <div style="font-size:11px;color:#888;margin-bottom:6px;">${l.clave} · ${l.cantPz > 0 ? l.cantPz+' pz' : ''} ${l.cantKg > 0 ? l.cantKg+' kg' : ''}</div>
          <div style="font-size:11px;color:#2D5A1B;font-weight:600;margin-bottom:8px;">📦 Stock: ${stock.toLocaleString('es-MX')} ${ubicProd?.unidad||''}</div>
          <input class="form-input" id="lote_cs_${i}" placeholder="Lote / Caducidad *"
            style="font-size:13px;padding:9px 12px;margin-bottom:8px;" required>
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="flex:1;">
              <div style="font-size:11px;color:#555;font-weight:700;margin-bottom:4px;">Cantidad a despachar</div>
              <input class="form-input" id="cant_cs_${i}"
                type="number" step="1" min="1"
                value="${l.cantPz > 0 ? l.cantPz : l.cantKg}"
                placeholder="Cantidad"
                style="font-size:13px;padding:9px 12px;">
            </div>
            <div style="font-size:11px;color:#888;padding-top:18px;">
              / ${l.cantPz > 0 ? l.cantPz.toLocaleString('es-MX')+' pz' : l.cantKg.toLocaleString('es-MX')+' kg'} pedidas
            </div>
          </div>
        </div>`;
    }).join('');
  }

  // Productos que se OMITEN
  if (sinStock.length) {
    html += `<div style="font-size:11px;font-weight:700;color:#E53935;letter-spacing:.06em;margin:12px 0 8px;padding:0 2px;">⛔ SE OMITIRÁN — SIN STOCK (${sinStock.length})</div>`;
    html += sinStock.map(l => `
      <div style="background:#FFF5F5;border-radius:12px;padding:12px 14px;margin-bottom:8px;border:1.5px solid #FFCDD2;opacity:0.8;">
