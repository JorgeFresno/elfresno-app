async function intentarLogin() {
  const user = document.getElementById('loginUser').value.trim();
  const pass = document.getElementById('loginPass').value.trim();
  const btn  = document.getElementById('loginBtn');
  const err  = document.getElementById('loginError');

  if (!user || !pass) {
    mostrarErrorLogin('Ingresa usuario y contraseña');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Verificando...';
  err.classList.remove('visible');

  try {
    // Cargar hoja Usuarios desde Sheets
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=Usuarios`;
    const res  = await fetch(url);
    const text = await res.text();
    const json = JSON.parse(text.substring(47).slice(0, -2));
    const rows = json.table.rows;

    // Buscar usuario — columnas: A=IdUsuario, B=NombreUsuario, C=Contraseña, D=Rol, E=Activo
    let encontrado = null;
    for (const row of rows) {
      const nombreSheet = String(row.c[1]?.v || '').trim().toLowerCase();
      const passSheet   = String(row.c[2]?.v || '').trim();
      const rol         = String(row.c[3]?.v || '').trim();
      const activo      = String(row.c[4]?.v || '').trim().toUpperCase();
      const id          = String(row.c[0]?.v || '').trim();

      // Comparar nombre (case insensitive) y contraseña (exacta)
      if (nombreSheet === user.toLowerCase() && passSheet === pass && activo === 'SI') {
        encontrado = { id, nombre: row.c[1].v, rol };
        break;
      }
    }

    if (encontrado) {
      currentUser = encontrado;
      // Guardar en sessionStorage para recargas
      localStorage.setItem('fresno_user', JSON.stringify(currentUser));
      aplicarLogin();
    } else {
      mostrarErrorLogin('Usuario o contraseña incorrectos');
    }

  } catch(e) {
    mostrarErrorLogin('Error de conexión — verifica tu internet');
    console.error('Login error:', e);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Entrar';
  }
}

function mostrarErrorLogin(msg) {
